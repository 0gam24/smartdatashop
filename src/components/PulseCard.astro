---
import { tagUrl, type TagGroup, type TagValue } from '../lib/tags';

interface PulseTag {
  label: string;
  /** 태그 그룹 — 지정되면 /tag/{group}/{label}/ 링크가 된다. 없으면 단순 span. */
  group?: TagGroup;
  action?: boolean;
}

interface Props {
  category: string;
  time: string;
  title: string;
  tldr: string;
  tags: PulseTag[];
  href?: string;
  /**
   * 옵셔널 coverImage URL (절대/상대 모두 허용). 전달되면 카드 좌측에 16:9
   * 썸네일 렌더링 — Discover 가 사이트 내부 시각 신호도 보기 때문에 site-self
   * visual hierarchy 강화 (G6).
   */
  coverImage?: string;
  /** 접근성용 alt — coverImage 가 있을 때만 의미 */
  coverImageAlt?: string;
}

const { category, time, title, tldr, tags, href, coverImage, coverImageAlt } = Astro.props;
---

<article class={coverImage ? 'pulse-card has-cover' : 'pulse-card'} data-href={href}>
  {href ? (
    <a class="card-link" href={href}>
      {coverImage && (
        <img
          class="pulse-cover"
          src={coverImage}
          alt={coverImageAlt ?? ''}
          width="320"
          height="180"
          loading="lazy"
          decoding="async"
        />
      )}
      <div class="pulse-card-text">
        <div class="pulse-card-meta">
          <span class="cat-label">{category}</span>
          <span class="pulse-time">{time}</span>
        </div>
        <h3 class="pulse-title">{title}</h3>
        <p class="pulse-tldr">{tldr}</p>
      </div>
    </a>
  ) : (
    <div class="card-link">
      {coverImage && (
        <img
          class="pulse-cover"
          src={coverImage}
          alt={coverImageAlt ?? ''}
          width="320"
          height="180"
          loading="lazy"
          decoding="async"
        />
      )}
      <div class="pulse-card-text">
        <div class="pulse-card-meta">
          <span class="cat-label">{category}</span>
          <span class="pulse-time">{time}</span>
        </div>
        <h3 class="pulse-title">{title}</h3>
        <p class="pulse-tldr">{tldr}</p>
      </div>
    </div>
  )}
  <div class="pulse-card-foot">
    {tags.map((tag) => (
      tag.group ? (
        <a
          class={tag.action ? 'tag-chip action' : 'tag-chip'}
          href={tagUrl(tag.group, tag.label as TagValue)}
        >{tag.label}</a>
      ) : (
        <span class={tag.action ? 'tag-chip action' : 'tag-chip'}>{tag.label}</span>
      )
    ))}
  </div>
</article>

<style>
  .pulse-card {
    padding: 24px 28px 24px 0;
    border-top: 0.5px solid var(--color-ink-quat);
    display: flex;
    flex-direction: column;
    gap: 10px;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .pulse-card:hover .pulse-title {
    color: var(--color-accent);
  }

  /* 카드 본문 링크 — 시각적으로는 보이지 않는 wrapper. coverImage 가 없으면
     단일 컬럼, 있으면 16:9 썸네일 좌측 + 텍스트 우측. */
  .card-link {
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: inherit;
    text-decoration: none;
  }
  .pulse-card.has-cover .card-link {
    flex-direction: row;
    gap: 20px;
    align-items: flex-start;
  }
  .pulse-card.has-cover .pulse-card-text {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1 1 auto;
    min-width: 0;
  }
  .pulse-cover {
    flex: 0 0 auto;
    width: 240px;
    height: 135px; /* 16:9 */
    object-fit: cover;
    border: 0.5px solid var(--color-ink-quat);
    background: var(--color-paper);
  }
  @media (max-width: 640px) {
    .pulse-card.has-cover .card-link {
      flex-direction: column;
      gap: 12px;
    }
    .pulse-cover {
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9;
    }
  }

  .pulse-card-meta {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-size: 12px;
  }
  .pulse-time {
    font-family: var(--font-mono);
    color: var(--color-ink-tertiary);
    letter-spacing: 0.05em;
    font-size: 11px;
  }
  .pulse-title {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.35;
    letter-spacing: -0.01em;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0;
    transition: color 0.15s ease;
  }
  .pulse-tldr {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-ink-secondary);
    margin: 0;
  }
  .pulse-card-foot {
    display: flex;
    gap: 6px;
    margin-top: 4px;
    flex-wrap: wrap;
  }
  .tag-chip {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-ink-tertiary);
    border: 0.5px solid var(--color-ink-quat);
    padding: 2px 8px;
    border-radius: 1px;
    text-decoration: none;
    display: inline-block;
  }
  .tag-chip.action {
    color: var(--color-accent);
    border-color: var(--color-accent-soft);
  }
  a.tag-chip:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-soft);
  }
</style>
