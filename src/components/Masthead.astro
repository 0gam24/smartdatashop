---
import { mastheadIssueNumber } from '../lib/korean';

interface Props {
  vol?: string;
  no?: string;
  todayCount?: number;
  totalCount?: number;
  tagline?: string;
  /**
   * 가장 최근 발행 글의 publishedAt (ISO 8601). 오늘의 글 0편일 때
   * "마지막 발행 X시간 전" freshness 신호 표시.
   */
  lastPublishedAt?: string;
}

// 기본값은 KST 오늘 기준 자동 계산 — 창간일 (2026-01-01) 부터 일수 + 1.
// 매시간 scout cron 빌드로 자연 갱신. props 명시 시 그 값 우선.
const _auto = mastheadIssueNumber();
const {
  vol = _auto.vol,
  no = _auto.no,
  todayCount = 0,
  totalCount = 0,
  tagline = '한국의 데이터를 매일 5분으로 — 1차 출처 데이터 저널',
  lastPublishedAt,
} = Astro.props;

/** 마지막 발행 후 경과 시간 — "23시간 전" / "2일 전" 류. 24h 미만은 시간, 이상은 일. */
function formatElapsed(isoString: string): string {
  const elapsed = Date.now() - new Date(isoString).getTime();
  const hours = Math.floor(elapsed / (1000 * 60 * 60));
  if (hours < 1) return '방금';
  if (hours < 24) return `${hours}시간 전`;
  const days = Math.floor(hours / 24);
  return `${days}일 전`;
}

const elapsedLabel = todayCount === 0 && lastPublishedAt ? formatElapsed(lastPublishedAt) : null;
---

<div class="masthead">
  <div class="page-width masthead-inner">
    <div class="masthead-tagline">{tagline}</div>
    <div class="masthead-counter">
      <span>VOL <strong>{vol}</strong>·NO <strong>{no}</strong></span>
      <span>
        오늘의 글 <strong>{todayCount}</strong>편
        {elapsedLabel && <span class="masthead-elapsed"> · 최근 <strong>{elapsedLabel}</strong></span>}
      </span>
      <span>누적 <strong>{totalCount}</strong>편</span>
    </div>
  </div>
</div>

<style>
  .masthead {
    border-bottom: 0.5px solid var(--color-ink-quat);
    padding: 14px 0;
    background: var(--color-paper);
  }
  .masthead-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--color-ink-secondary);
  }
  .masthead-tagline {
    font-family: var(--font-serif);
    font-size: 13px;
    font-style: italic;
    color: var(--color-ink-secondary);
  }
  .masthead-counter {
    display: flex;
    gap: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
  }
  .masthead-counter span :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .masthead-elapsed {
    color: var(--color-accent);
  }
  @media (max-width: 640px) {
    .masthead-counter { display: none; }
  }
</style>
