---
/**
 * 전체 아카이브 — /category/all/
 *
 * 모든 펄스 + 인사이트를 카테고리 구분 없이 하나의 최신순 흐름으로 보여 주는
 * "전체(All)" 뷰. /category/{slug}/(카테고리별 아카이브)와 짝을 이루며,
 * 사용자가 분야에 상관없이 최신 글 전체를 한 페이지에서 훑을 수 있게 한다.
 *
 * 구성:
 *  - 통계: 전체 발행 글 수 + 인용 1차 출처 수 + 최근 12개월 발행 분포
 *  - 목록: 펄스 + 인사이트를 publishedAt 내림차순으로 병합, PulseCard 그리드
 *
 * 시각 언어: /category/{slug}/ 와 동일 (박스/그림자 없음, hairline만, mono/serif).
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Masthead from '../../../components/Masthead.astro';
import SectionHead from '../../../components/SectionHead.astro';
import PulseList from '../../../components/PulseList.astro';
import PulseCard from '../../../components/PulseCard.astro';
import Footer from '../../../components/Footer.astro';
import KpiTile from '../../../components/viz/KpiTile.astro';
import BarSpark from '../../../components/viz/BarSpark.astro';
import {
  categoryToKorean,
  formatKoreanTime,
  pulseDateParts,
  pulseUrl,
  insightUrl,
  kstTodayIso,
} from '../../../lib/korean';
import {
  buildBreadcrumbLD,
  buildCollectionPageLD,
  buildItemListLD,
} from '../../../lib/jsonld';

// ── 전체 펄스 + 인사이트 병합, 최신 우선 ─────────────────────────────
const allPulses = await getCollection('pulse');
const allInsights = await getCollection('insight');

type Merged = {
  publishedAt: string;
  kind: 'pulse' | 'insight';
  entry: any;
};
const merged: Merged[] = [
  ...allPulses.map((e) => ({ publishedAt: String(e.data.publishedAt), kind: 'pulse' as const, entry: e })),
  ...allInsights.map((e) => ({ publishedAt: String(e.data.publishedAt), kind: 'insight' as const, entry: e })),
].sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

// PulseCard 매핑 — 카테고리 허브(index.astro 섹션 02)와 동일한 태그 규칙(persona+dataType+action, slice 3)
const cards = merged.map(({ entry, kind }) => {
  const { personas, dataTypes, actions } = entry.data.tags;
  const tags = [
    ...personas.map((label: string) => ({ label })),
    ...dataTypes.map((label: string) => ({ label })),
    ...actions.map((label: string) => ({ label, action: true })),
  ].slice(0, 3);
  const { year, month, day } = pulseDateParts(entry.data.publishedAt);
  return {
    category: categoryToKorean(entry.data.category),
    time: `${year}.${month}.${day} · ${formatKoreanTime(entry.data.publishedAt)}`,
    title: entry.data.title,
    tldr: entry.data.tldr,
    href:
      kind === 'pulse'
        ? pulseUrl(entry.slug, entry.data.publishedAt, entry.data.category)
        : insightUrl(entry.slug, entry.data.publishedAt),
    tags,
    coverImage: entry.data.coverImage,
  };
});

const totalCount = merged.length;
const todayIso = kstTodayIso();
const todayCount = merged.filter((m) => m.publishedAt.slice(0, 10) === todayIso).length;

// 통계 — 인용 1차 출처 수(중복 제거)
const uniqueSourceUrls = new Set<string>();
for (const e of allPulses) e.data.sources.forEach((s) => uniqueSourceUrls.add(s.url));
for (const e of allInsights) e.data.sources.forEach((s) => uniqueSourceUrls.add(s.url));

// 최근 12개월 발행 분포 (BarSpark)
const now = new Date();
const monthBuckets: number[] = new Array(12).fill(0);
const monthLabels: string[] = [];
for (let i = 11; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  monthLabels.push(`${(d.getMonth() + 1).toString().padStart(2, '0')}`);
}
function bucketIndex(publishedAt: string): number {
  const d = new Date(publishedAt);
  const monthsAgo = (now.getFullYear() - d.getFullYear()) * 12 + (now.getMonth() - d.getMonth());
  return monthsAgo >= 0 && monthsAgo < 12 ? 11 - monthsAgo : -1;
}
for (const m of merged) {
  const idx = bucketIndex(m.publishedAt);
  if (idx >= 0) monthBuckets[idx]++;
}
const monthlyMax = Math.max(...monthBuckets, 1);
const hasAnyPublished = monthBuckets.some((n) => n > 0);

// SEO 메타
const pageTitle = '전체 글 — 스마트데이터샵';
const pageDescription = '스마트데이터샵의 정책·세금·금융·시장·통계·AI 글 전체를 최신순으로 모았습니다. 카테고리 구분 없이 1차 출처 데이터 저널의 모든 발행 글을 한 페이지에서 확인하세요.';

// JSON-LD: CollectionPage + ItemList + BreadcrumbList
const pageUrl = '/category/all/';
const collectionLd = buildCollectionPageLD(pageTitle, pageDescription, pageUrl);
const itemListLd = buildItemListLD(cards.map((c) => ({ name: c.title, url: c.href })));
const breadcrumbLd = buildBreadcrumbLD([
  { name: '홈', url: '/' },
  { name: '전체', url: pageUrl },
]);
const jsonld: object[] = [collectionLd, itemListLd, breadcrumbLd];
const keywords = ['전체 글', '최신순', '데이터 저널', '1차 출처'];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogType="website"
  jsonld={jsonld}
  keywords={keywords}
>
  <Header activeNav="all" />
  <Masthead
    todayCount={todayCount}
    totalCount={totalCount}
    tagline="전체 아카이브 · 최신순"
  />

  <main id="main" role="main">
    <h1 class="visually-hidden">전체 글 — 1차 출처 데이터 아카이브 (최신순)</h1>

    {totalCount > 0 && (
      <section class="section cat-stats-section" data-screen-label="전체 통계">
        <div class="page-width">
          <div class="cat-stats">
            <KpiTile title="전체 발행 글" n={totalCount} unit="편" change={`오늘 ${todayCount}편 · 최신순`} />
            <KpiTile title="인용 1차 출처" n={uniqueSourceUrls.size} unit="건" change="중복 제거" />
            {hasAnyPublished && (
              <figure class="cat-monthly">
                <figcaption class="cat-monthly-title">최근 12개월 발행 분포</figcaption>
                <BarSpark
                  values={monthBuckets}
                  labels={monthLabels}
                  max={monthlyMax}
                  width={240}
                  height={40}
                  ariaLabel="전체 글의 최근 12개월 월별 발행 건수"
                />
              </figure>
            )}
          </div>
        </div>
      </section>
    )}

    <section class="section" data-screen-label="전체 아카이브">
      <div class="page-width">
        <SectionHead num="·" title="전체 글" moreLabel={`${totalCount}편 · 최신순`} />

        {totalCount === 0 ? (
          <div class="empty">아직 발행된 글이 없습니다 — 곧 첫 글이 올라옵니다.</div>
        ) : (
          <PulseList>
            {cards.map((p) => <PulseCard {...p} />)}
          </PulseList>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .cat-stats-section {
    padding-top: 32px;
    padding-bottom: 32px;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .cat-stats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    align-items: stretch;
  }
  @media (max-width: 720px) {
    .cat-stats { grid-template-columns: 1fr; }
  }
  .cat-monthly {
    border: 0.5px solid var(--color-ink-quat);
    background: var(--color-paper-soft);
    padding: 16px 18px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cat-monthly-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--color-ink-tertiary);
    text-transform: uppercase;
  }
  .empty {
    border: 0.5px dashed var(--color-ink-quat);
    padding: 36px 24px;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink-secondary);
    text-align: center;
  }
</style>
