---
import { formatKoreanToday } from '../lib/korean';

interface Props {
  date?: string;
  activeNav?: 'daily' | 'all' | 'insight' | 'guidebook' | 'notice' | 'data' | 'network';
}

// 기본값은 빌드 시점의 KST 오늘 — hourly scout bot 으로 매시간 자동 갱신.
const { date = formatKoreanToday(), activeNav = 'daily' } = Astro.props;

// 콘텐츠 우선 nav — AdSense 재거절 대응(2026-07-14). 자동 fetch·정부 RSS 재게시
// 성격의 /data/*·/topic/* 은 noindex + sitemap 제외로 전환했으므로, 크롤러를 얇은
// 페이지로 유도하지 않도록 메인 nav 에서 데이터·정부발표를 내린다. 두 항목은 Footer
// 에 그대로 남겨 사용자 접근성은 유지(색인만 차단, 페이지는 살아 있음).
const navItems: Array<{ key: NonNullable<Props['activeNav']>; label: string; href: string }> = [
  { key: 'daily', label: '데일리', href: '/' },
  { key: 'all', label: '전체', href: '/category/all/' },
  { key: 'insight', label: '인사이트', href: '/insight/' },
  { key: 'guidebook', label: '가이드북', href: '/guidebook/' },
];
---

<header class="site-header" data-screen-label="Header">
  <div class="page-width header-inner">
    <a href="/" class="logo no-underline">
      스마트데이터샵 <span class="tld">.kr</span>
    </a>
    <nav class="nav-primary">
      {navItems.map((item) => (
        <a href={item.href} class={item.key === activeNav ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>
    <div class="header-right">
      <span class="header-date">{date}</span>
      <button class="search-btn" type="button" data-search-trigger aria-label="기사 검색 열기">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="7" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        검색
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 0.5px solid var(--color-ink-quat);
    background: rgba(250, 247, 240, 0.92);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(6px);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 32px;
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .logo :global(.tld) {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    font-weight: 500;
  }
  .nav-primary {
    display: flex;
    gap: 28px;
    font-size: 14px;
    color: var(--color-ink);
  }
  .nav-primary a {
    color: var(--color-ink);
    position: relative;
    padding: 4px 0;
  }
  .nav-primary a.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -22px;
    height: 1.5px;
    background: var(--color-accent);
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .header-date {
    font-family: var(--font-serif);
    font-size: 13px;
    color: var(--color-ink-secondary);
  }
  .search-btn {
    background: none;
    border: 0.5px solid var(--color-ink-quat);
    color: var(--color-ink-secondary);
    padding: 6px 10px;
    border-radius: 2px;
    font-family: var(--font-sans);
    font-size: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    letter-spacing: 0.05em;
  }
  .search-btn:hover {
    border-color: var(--color-ink-secondary);
    color: var(--color-ink);
  }
  .search-btn svg {
    width: 12px;
    height: 12px;
  }

  @media (max-width: 880px) {
    .nav-primary { display: none; }
    .header-date { display: none; }
  }
</style>
