---
import PolicyLayout from '../../layouts/PolicyLayout.astro';
import { AUTHOR_KNOWS_ABOUT, buildPersonLD, buildBreadcrumbLD } from '../../lib/jsonld';

// 저자 페이지 LD: Person + Breadcrumb (홈 › 저자 › 김준혁).
// PUBLIC_AUTHOR_SAMEAS 환경변수로 외부 프로필 URL 자동 주입 (LinkedIn/네이버블로그/X 등) —
// 코드 변경 없이 운영자가 즉시 채울 수 있도록 분리.
const personLd = buildPersonLD();
const breadcrumbLd = buildBreadcrumbLD([
  { name: '홈', url: '/' },
  { name: '저자', url: '/' },
  { name: '김준혁', url: '/authors/junhyuk-kim/' },
]);

// PUBLIC_AUTHOR_SAMEAS 환경변수에서 직접 표시용 목록 추출 (jsonld.ts 의 동일 파싱).
const sameAsRaw = (import.meta.env.PUBLIC_AUTHOR_SAMEAS as string | undefined) ?? '';
const sameAsLinks = sameAsRaw
  .split(',')
  .map((s) => s.trim())
  .filter(Boolean);

function hostnameOf(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
}
---

<PolicyLayout
  title="김준혁"
  eyebrow="A U T H O R"
  description="스마트데이터샵 운영자·편집장 김준혁. 한국 정부·공공기관 1차 출처 데이터 저널리즘."
  ogImage="https://smartdatashop.kr/og/v2/author/junhyuk-kim.png"
  jsonld={[personLd, breadcrumbLd]}
>
  <h2>역할</h2>
  <table class="meta-table">
    <tr><th>이름</th><td>김준혁 (Junhyuk Kim)</td></tr>
    <tr><th>직책</th><td>대표 · 편집장 · 데이터 검증 책임자</td></tr>
    <tr><th>이메일</th><td><a href="mailto:editor@smartdatashop.kr">editor@smartdatashop.kr</a></td></tr>
    <tr><th>소속</th><td>스마트데이터샵 (사업자등록번호 406-06-34485)</td></tr>
    <tr><th>본거지</th><td>인천광역시 계양구 새벌로 88, 302동 1007호</td></tr>
  </table>

  <h2>전문 분야 (knowsAbout)</h2>
  <p class="meta-note">아래 항목은 Person JSON-LD <code>knowsAbout</code> 배열과 동기화 — 검색엔진의 author topical authority 신호.</p>
  <ul class="expertise-list">
    {AUTHOR_KNOWS_ABOUT.map((topic) => <li>{topic}</li>)}
  </ul>

  <h2>활동 영역</h2>
  <ul>
    <li><strong>1인사업자·사회초년생·신혼부부 대상</strong> 정책·세금·금융 가이드</li>
    <li><strong>데이터 시각화</strong> 및 비전문가용 해설 (가이드북 시리즈)</li>
    <li><strong>AI 보조 작성 + 1차 출처 검증</strong>을 결합한 데이터 저널리즘 워크플로우 (ADR 0005 — Layer 1~5 자동 안전장치)</li>
  </ul>

  <h2>발행 윤리</h2>
  <p>
    본 사이트의 모든 글은 <a href="/editorial-policy/">편집정책</a>과 <a href="/ai-policy/">AI 정책</a>을 따릅니다.
    AI 보조로 작성된 글은 본문 상단 Trust Bar 에 명시되며, 1차 출처 검증과 최종 발행 결정은 본인이 합니다.
    오류 발견 시 <a href="/corrections/">정정 이력</a>에 공개적으로 기록합니다.
  </p>

  <h2>외부 프로필</h2>
  {sameAsLinks.length === 0 ? (
    <p class="env-hint">
      ⚙️ 운영자 액션 — Cloudflare Pages 환경변수 <code>PUBLIC_AUTHOR_SAMEAS</code> 에
      LinkedIn / 네이버 블로그 / X / Brunch 등 본인이 보유한 외부 프로필 URL 을
      콤마 구분으로 입력하면 본 섹션과 Person JSON-LD <code>sameAs</code> 에 자동 반영됩니다.
    </p>
  ) : (
    <ul class="profile-list">
      {sameAsLinks.map((url) => (
        <li>
          <a href={url} rel="noopener noreferrer me" target="_blank">
            {hostnameOf(url)}
          </a>
        </li>
      ))}
    </ul>
  )}

  <h2>연락</h2>
  <p>제보·정정·인터뷰 요청은 <a href="mailto:editor@smartdatashop.kr">editor@smartdatashop.kr</a> 또는 <a href="/contact/">/contact/</a> 양식.</p>
</PolicyLayout>

<style>
  .profile-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .profile-list li {
    margin: 0;
  }
  .profile-list a {
    display: inline-block;
    border: 0.5px solid var(--color-ink-quat);
    padding: 6px 12px;
    font-size: 13px;
    color: var(--color-ink-secondary);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }
  .profile-list a:hover {
    border-color: var(--color-accent-soft);
    color: var(--color-accent);
  }
  .env-hint {
    display: block;
    border: 0.5px solid var(--color-ink-quat);
    background: var(--color-paper-soft);
    color: var(--color-ink-secondary);
    padding: 12px 16px;
    margin: 1rem 0 1.5rem;
    font-size: 12px;
    font-family: var(--font-mono);
    line-height: 1.6;
    letter-spacing: 0.01em;
  }
  .env-hint code {
    color: var(--color-accent);
    font-size: 11px;
    padding: 1px 5px;
    border: 0.5px solid var(--color-ink-quat);
    background: var(--color-paper);
  }
  .meta-note {
    font-size: 12px;
    color: var(--color-ink-tertiary);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }
  .meta-note code {
    color: var(--color-ink-secondary);
    background: var(--color-paper-soft);
    padding: 1px 6px;
    border: 0.5px solid var(--color-ink-quat);
  }
  .expertise-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 6px 24px;
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }
  @media (max-width: 560px) {
    .expertise-list { grid-template-columns: 1fr; }
  }
</style>
