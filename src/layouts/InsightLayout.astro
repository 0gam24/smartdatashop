---
/**
 * InsightLayout — 인사이트(에버그린 심층분석) 전용 레이아웃.
 *
 * ArticleLayout과의 차이:
 *   1. Header activeNav="insight" (펄스는 "daily")
 *   2. 브레드크럼: 홈 › 인사이트 › 카테고리 (펄스는 데일리 › 카테고리 › 날짜)
 *   3. 펄스의 ToollGate "원문 →" 의례가 본문 외부 강제 슬롯에 없음 — 인사이트는
 *      본문 자체가 심층 분석이므로 페이로드 안에서 필요시 호출자가 직접 사용.
 *
 * 동일하게 유지:
 *   - var(--width-prose) prose 폭, ArticleHeader, SourceList, related slot, MDX 각주 처리.
 */
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import ArticleHeader from '../components/ArticleHeader.astro';
import TrustBar from '../components/TrustBar.astro';
import SourceList from '../components/SourceList.astro';
import AuthorCard from '../components/AuthorCard.astro';
import CorrectionsBlock from '../components/CorrectionsBlock.astro';
import Footer from '../components/Footer.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import CitationExport from '../components/CitationExport.astro';
import { categoryToKorean, formatKoreanDate, type Category } from '../lib/korean';
import { buildBreadcrumbLD, buildPersonLD } from '../lib/jsonld';

interface Source {
  name: string;
  url?: string;
  date?: string;
  accessedAt?: string;
  note?: string;
}

interface Correction {
  date: string;
  description: string;
}

interface Props {
  category: Category;
  publishedAt: string;
  updatedAt?: string;
  title: string;
  author?: string;
  /** 인사이트는 frontmatter의 estimatedReadingTime을 그대로 사용 */
  readingTime: number;
  sources: Source[];
  aiAssisted: false | 'edit' | 'draft' | 'fact-check';
  vol?: string;
  no?: string;
  /** 정정 이력 — 비어 있으면 CorrectionsBlock은 렌더되지 않는다 */
  corrections?: Correction[];
  /** 페이지 keywords meta — 페르소나/데이터유형/액션 태그 등에서 도출. */
  keywords?: string[];
  /** OG 이미지 절대 URL. 미지정 시 BaseLayout의 og-default.png 사용. */
  ogImage?: string;
  /**
   * true 일 때 robots noindex,nofollow 메타가 출력된다.
   * 동적 라우트가 placeholder 텍스트를 검출했을 때 색인 자동 차단용.
   */
  noindex?: boolean;
  /**
   * 호출자가 JSON-LD 객체(배열) 를 직접 전달 — Article + Breadcrumb + Dataset 등을
   * 라우트에서 미리 빌드해 BaseLayout 으로 통합 발행한다.
   * G10 픽스: 그동안 인사이트 페이지 LD 가 0개여서 Discover 진입 자격 손실.
   */
  jsonld?: object | object[];
}

const {
  category,
  publishedAt,
  updatedAt,
  title,
  author = '김준혁',
  readingTime,
  sources,
  aiAssisted,
  vol = 'I',
  no = '89',
  corrections = [],
  keywords,
  ogImage,
  noindex = false,
  jsonld,
} = Astro.props;

const headerDate = formatKoreanDate(publishedAt);
const pageTitle = `${title} — 스마트데이터샵 인사이트`;

// 인사이트 브레드크럼: 홈 › 인사이트 › 카테고리
// BreadcrumbMasthead는 "데일리"가 하드코딩돼 있어 인라인으로 별도 구성.
const categoryLabel = categoryToKorean(category).replace(/ /g, '');

// BreadcrumbList LD + Person LD 자동 병합 (호출자 jsonld + 자동 LD 통합)
// 06 §3 E-E-A-T / 07 §3 D.I.A. 저자 신뢰성 / 06 §11 BreadcrumbList 리치결과
const insightBreadcrumb = buildBreadcrumbLD([
  { name: '홈', url: '/' },
  { name: '인사이트', url: '/insight/' },
  { name: categoryLabel, url: `/insight/category/${category}/` },
  { name: title, url: Astro.url.pathname },
]);
const incomingJsonld = jsonld
  ? Array.isArray(jsonld)
    ? jsonld
    : [jsonld]
  : [];
const mergedJsonld: object[] = [...incomingJsonld, insightBreadcrumb, buildPersonLD()];
---

<BaseLayout title={pageTitle} ogType="article" ogPublishedAt={publishedAt} ogModifiedAt={updatedAt} keywords={keywords} ogImage={ogImage} noindex={noindex} jsonld={mergedJsonld}>
  <Header activeNav="insight" date={headerDate} />

  <div class="masthead">
    <div class="page-width masthead-inner">
      <div class="masthead-tagline">
        <a href="/" class="no-underline crumb-link">홈</a>
        <span class="dot">›</span>
        <a href="/insight/" class="no-underline crumb-link">인사이트</a>
        <span class="dot">›</span>
        <span class="crumb-current">{categoryLabel}</span>
      </div>
      <div class="masthead-counter">
        <span>VOL <strong>{vol}</strong>·NO <strong>{no}</strong></span>
        <span>인사이트 · 에버그린</span>
      </div>
    </div>
  </div>

  <main id="main" role="main" class="article-wrap" data-screen-label="인사이트 글">
    <ArticleTOC />

    <ArticleHeader
      category={category}
      publishedAt={publishedAt}
      title={title}
      author={author}
      readingTime={readingTime}
      sourceCount={sources.length}
      aiAssisted={aiAssisted}
      updatedAt={updatedAt}
    />

    <div class="article-body">
      <TrustBar
        aiAssisted={aiAssisted}
        sourceCount={sources.length}
        updatedAt={updatedAt ?? publishedAt}
        correctionsCount={corrections.length}
      />
      <slot />
      <AuthorCard name={author} />
      <CitationExport
        title={title}
        publishedAt={publishedAt}
        url={Astro.url.toString()}
        author={author}
      />
      <CorrectionsBlock corrections={corrections} />
      <hr />
      <SourceList sources={sources} />
    </div>

    <slot name="related" />
  </main>

  <Footer vol={vol} no={no} date={headerDate} />
</BaseLayout>

<style>
  .masthead {
    border-bottom: 0.5px solid var(--color-ink-quat);
    padding: 14px 0;
    background: var(--color-paper);
  }
  .masthead-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--color-ink-secondary);
  }
  .masthead-tagline {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--color-ink-secondary);
  }
  .crumb-link {
    color: var(--color-ink-secondary);
  }
  .crumb-current {
    color: var(--color-ink);
  }
  .masthead-counter {
    display: flex;
    gap: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
  }
  .masthead-counter span :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  .article-wrap {
    padding: 48px 0 64px;
  }
  .article-body {
    max-width: var(--width-prose);
    margin: 0 auto;
    padding: 0 var(--width-gutter);
  }
  .article-body :global(p) {
    margin-bottom: 1.4rem;
  }
  .article-body :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .article-body :global(hr) {
    border: 0;
    border-top: 0.5px solid var(--color-ink-quat);
    margin: 2rem 0;
  }
</style>

<!--
  MDX 각주 스타일링 — ArticleLayout과 동일한 처리(사유 동일).
-->
<style is:global>
  .article-body sup[data-footnote-ref],
  .article-body sup.footnote-ref {
    font-size: 10px;
    vertical-align: super;
    line-height: 0;
    margin: 0 1px;
  }
  .article-body sup[data-footnote-ref] a,
  .article-body sup.footnote-ref a {
    color: var(--color-accent);
    font-weight: 500;
    font-family: var(--font-sans);
    text-decoration: none;
  }
  .article-body section[data-footnotes] {
    display: none;
  }

  /* 본문 표 — 가운데 정렬·해어라인·헤더 강조 (ArticleLayout 와 동일, 2026-06-15).
     DESIGN.md v1.0 준수: 그림자·radius·카테고리 컬러 없음, 디자인 토큰만, font-weight ≤500. */
  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.6rem 0;
    font-size: 15px;
    line-height: 1.55;
    font-variant-numeric: tabular-nums;
  }
  .article-body thead th {
    text-align: center;
    font-weight: 500;
    background: var(--color-paper-soft);
    border-top: 1px solid var(--color-ink-tertiary);
    border-bottom: 1px solid var(--color-ink-tertiary);
    padding: 11px 12px;
    white-space: nowrap;
  }
  .article-body tbody td {
    text-align: center;
    padding: 10px 12px;
    border-bottom: 0.5px solid var(--color-ink-quat);
    word-break: keep-all;
    vertical-align: middle;
  }
  .article-body tbody td:first-child {
    font-weight: 500;
    color: var(--color-ink);
  }
  .article-body tbody tr:last-child td {
    border-bottom: 1px solid var(--color-ink-tertiary);
  }
  @media (max-width: 480px) {
    .article-body table { font-size: 13px; }
    .article-body thead th { padding: 9px 6px; }
    .article-body tbody td { padding: 9px 6px; }
  }
</style>
