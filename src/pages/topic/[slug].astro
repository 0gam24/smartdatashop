---
/**
 * 주제 큐레이션 페이지 — /topic/{slug}/
 *
 * src/data/topics.ts 의 TopicConfig 를 기반으로 모든 컬렉션(pulse·insight·
 * guidebookChapter) 에서 매칭 글을 수집하고 viz 컴포넌트로 한 페이지에 합성.
 */
import { getCollection } from 'astro:content';
import { readFileSync, existsSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ChartLib from '../../components/ChartLib.astro';
import KpiTile from '../../components/viz/KpiTile.astro';
import {
  buildBreadcrumbLD,
  buildCollectionPageLD,
  buildItemListLD,
  buildDatasetLD,
} from '../../lib/jsonld';
import { pulseUrl, insightUrl, formatKoreanDate } from '../../lib/korean';
import { TOPICS, type TopicConfig } from '../../data/topics';

export async function getStaticPaths() {
  return TOPICS.map((t) => ({ params: { slug: t.slug }, props: { config: t } }));
}

interface Props {
  config: TopicConfig;
}
const { config } = Astro.props as Props;

const [pulses, insights, books, chapters] = await Promise.all([
  getCollection('pulse'),
  getCollection('insight'),
  getCollection('guidebook'),
  getCollection('guidebookChapter'),
]);

// ───────────────────────────────────────────────────────────────────
// ECOS 시계열 (config.ecosSeriesId 가 있을 때만)
// ───────────────────────────────────────────────────────────────────

type EcosPoint = { time: string | null; value: number | null };
type EcosSeries = {
  id: string;
  label: string;
  short: string;
  cycle: 'M' | 'D' | 'Q' | 'Y';
  unit: string;
  status: 'ok' | 'fail';
  pointCount: number;
  meta: { statName: string | null; itemName: string | null; unitName: string | null } | null;
  latest: EcosPoint | null;
  change: { abs: number; pct: number } | null;
  yoyChange: { abs: number; pct: number } | null;
  points: EcosPoint[];
};

let ecosSeries: EcosSeries | null = null;
let ecosFetchedAt: string | null = null;
if (config.ecosSeriesId) {
  const tsPath = resolve(process.cwd(), 'data/economy/ecos-timeseries.json');
  if (existsSync(tsPath)) {
    try {
      const j = JSON.parse(readFileSync(tsPath, 'utf8'));
      ecosFetchedAt = j.fetchedAt ?? null;
      const found = (j.series ?? []).find((s: any) => s.id === config.ecosSeriesId);
      if (found && found.status === 'ok') ecosSeries = found as EcosSeries;
    } catch {}
  }
}

function fmtTimeShort(t: string | null, cycle: string): string {
  if (!t) return '—';
  if (cycle === 'D' && t.length === 8) return `${t.slice(4, 6)}.${t.slice(6, 8)}`;
  if (cycle === 'M' && t.length === 6) return `${t.slice(0, 4)}.${t.slice(4, 6)}`;
  return t;
}

function fmtNum(n: number | null | undefined, decimals = 2): string {
  if (n == null || !Number.isFinite(n)) return '—';
  return n.toLocaleString('ko-KR', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
}

function fmtPct(n: number | null | undefined): string {
  if (n == null || !Number.isFinite(n)) return '—';
  const sign = n > 0 ? '+' : '';
  return `${sign}${n.toFixed(2)}%`;
}

const chartPayload = ecosSeries
  ? {
      id: ecosSeries.id,
      label: ecosSeries.short,
      cycle: ecosSeries.cycle,
      unit: ecosSeries.meta?.unitName ?? ecosSeries.unit,
      labels: ecosSeries.points.map((p) => fmtTimeShort(p.time, ecosSeries.cycle)),
      values: ecosSeries.points.map((p) => p.value),
    }
  : null;

function matchByTitle(title: string): boolean {
  return config.match.titleIncludes ? config.match.titleIncludes.test(title) : false;
}

const matchedPulses = pulses
  .filter((e) => {
    const cat = e.data.category;
    const byCat = config.match.pulseCategory?.includes(cat) ?? false;
    return byCat || matchByTitle(e.data.title);
  })
  .sort(
    (a, b) =>
      new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
  );

const matchedInsights = insights
  .filter((e) => {
    const cat = e.data.category;
    const byCat = config.match.insightCategory?.includes(cat) ?? false;
    return byCat || matchByTitle(e.data.title);
  })
  .sort(
    (a, b) =>
      new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
  );

const matchedBooks = books.filter((b) => {
  const id = b.id.replace(/\.json$/, '');
  return config.match.guidebookSlug?.includes(id) ?? false;
});

const matchedChapters = chapters
  .filter((c) => {
    const inBook = config.match.guidebookSlug?.includes(c.data.bookSlug) ?? false;
    return inBook || matchByTitle(c.data.title);
  })
  .sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);

// 1차 출처 dedupe — 동일 url 은 1회만 카운트
const sourceUrls = new Set<string>();
for (const e of matchedPulses) e.data.sources.forEach((s) => sourceUrls.add(s.url));
for (const e of matchedInsights) e.data.sources.forEach((s) => sourceUrls.add(s.url));
for (const e of matchedChapters) e.data.sources.forEach((s) => sourceUrls.add(s.url));

const pageUrl = `/topic/${config.slug}/`;
const pageTitle = `${config.title} — 스마트데이터샵`;

const collectionLd = buildCollectionPageLD(pageTitle, config.description, pageUrl);
const breadcrumbLd = buildBreadcrumbLD([
  { name: '홈', url: '/' },
  { name: '주제', url: '/' },
  { name: config.title, url: pageUrl },
]);

// ItemList — Discover 가 큐레이션 페이지로 인식하는 구조 신호
type Item = { name: string; url: string };
const itemListSrc: Item[] = [
  ...matchedBooks.map((b) => ({
    name: b.data.title,
    url: `/guidebook/${b.id.replace(/\.json$/, '')}/`,
  })),
  ...matchedInsights.map((e) => ({ name: e.data.title, url: insightUrl(e.slug) })),
  ...matchedPulses.map((e) => ({
    name: e.data.title,
    url: pulseUrl(e.slug, e.data.publishedAt),
  })),
];
const itemListLd = buildItemListLD(itemListSrc);

// ecosSeries 가 있는 토픽 페이지는 Dataset LD 추가 — Google Dataset Search 색인 자격.
// 1차 출처 = 한국은행 ECOS, 본 페이지가 raw 시계열을 차트·표로 시각화한 큐레이션.
// (07 §13 / 06 §12 — 데이터 저널 차별화 LD)
const datasetLd = ecosSeries && config.ecosSeriesId
  ? buildDatasetLD({
      name: `${ecosSeries.label} 시계열 (한국은행 ECOS)`,
      description:
        `${ecosSeries.label} 의 한국은행 ECOS 1차 출처 시계열 데이터 — ` +
        `${ecosSeries.pointCount}개 관측치, ${ecosSeries.cycle === 'D' ? '일별' : ecosSeries.cycle === 'M' ? '월별' : ecosSeries.cycle === 'Q' ? '분기별' : '연별'}, ` +
        `단위 ${ecosSeries.meta?.unitName ?? ecosSeries.unit}.`,
      url: pageUrl,
      sourceUrl: 'https://ecos.bok.or.kr/',
      sourceName: '한국은행 ECOS',
      publisher: '한국은행',
      datePublished: ecosSeries.latest?.time ?? undefined,
    })
  : null;

const jsonldArray: object[] = [collectionLd, breadcrumbLd, itemListLd];
if (datasetLd) jsonldArray.push(datasetLd);

const totalItems = matchedPulses.length + matchedInsights.length + matchedChapters.length;
---

<BaseLayout
  title={pageTitle}
  description={config.description}
  jsonld={jsonldArray}
>
  <Header />
  {ecosSeries && <ChartLib />}

  <main id="main" role="main" class="topic-wrap">
    <header class="topic-header">
      <div class="topic-eyebrow">{config.eyebrow}</div>
      <h1 class="topic-title">{config.title}</h1>
      {config.lead && <p class="topic-lead">{config.lead}</p>}
    </header>

    {ecosSeries && (
      <section class="topic-chart">
        <div class="tc-head">
          <div>
            <h2 class="tc-title">{ecosSeries.label} — 실시간 추이</h2>
            <p class="tc-meta">
              {ecosSeries.meta?.statName ?? ''} · 한국은행 ECOS 1차 자료 · 매일 자동 갱신
              {ecosFetchedAt && (
                <> · 마지막 갱신 {new Date(ecosFetchedAt).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' })}</>
              )}
            </p>
          </div>
          <div class="tc-stats">
            <div class="tc-stat">
              <div class="tc-stat-label">최신</div>
              <div class="tc-stat-value">
                {fmtNum(ecosSeries.latest?.value ?? null, 2)}<span class="tc-stat-unit">{ecosSeries.meta?.unitName ?? ecosSeries.unit}</span>
              </div>
              <div class="tc-stat-meta">{fmtTimeShort(ecosSeries.latest?.time ?? null, ecosSeries.cycle)}</div>
            </div>
            {ecosSeries.change && (
              <div class="tc-stat">
                <div class="tc-stat-label">{ecosSeries.cycle === 'D' ? '전일' : '전월'}</div>
                <div class={`tc-stat-value tc-delta-${ecosSeries.change.abs > 0 ? 'up' : ecosSeries.change.abs < 0 ? 'down' : 'flat'}`}>
                  {ecosSeries.change.abs > 0 ? '▲' : ecosSeries.change.abs < 0 ? '▼' : '·'}{' '}{fmtPct(ecosSeries.change.pct)}
                </div>
                <div class="tc-stat-meta">{fmtNum(Math.abs(ecosSeries.change.abs), 2)}</div>
              </div>
            )}
            {ecosSeries.yoyChange && (
              <div class="tc-stat">
                <div class="tc-stat-label">전년 동기</div>
                <div class={`tc-stat-value tc-delta-${ecosSeries.yoyChange.abs > 0 ? 'up' : ecosSeries.yoyChange.abs < 0 ? 'down' : 'flat'}`}>
                  {fmtPct(ecosSeries.yoyChange.pct)}
                </div>
                <div class="tc-stat-meta">{fmtNum(ecosSeries.yoyChange.abs, 2)}</div>
              </div>
            )}
          </div>
        </div>
        <div class="tc-canvas-wrap">
          <canvas id={`topic-chart-${ecosSeries.id}`} aria-label={`${ecosSeries.label} 추이 차트`} role="img"></canvas>
        </div>
        <p class="tc-foot">
          전체 시계열·다른 지표는 <a href="/data/timeseries/">/data/timeseries/</a>,
          출처 정책은 <a href="/methodology/">/methodology/</a> 참조.
        </p>
      </section>
    )}

    <section class="topic-stats">
      <KpiTile title="발행 글" n={totalItems} unit="편" />
      <KpiTile title="가이드북" n={matchedBooks.length} unit="권" />
      <KpiTile title="인용 1차 출처 (dedupe)" n={sourceUrls.size} unit="개" />
    </section>

    {matchedBooks.length > 0 && (
      <section class="topic-section">
        <h2>가이드북</h2>
        <ul class="topic-list">
          {matchedBooks.map((b) => {
            const slug = b.id.replace(/\.json$/, '');
            const pct =
              b.data.totalChapters > 0
                ? Math.round((b.data.completedChapters / b.data.totalChapters) * 100)
                : 0;
            return (
              <li>
                <a href={`/guidebook/${slug}/`} class="no-underline">
                  <span class="t-title">{b.data.title}</span>
                  <span class="t-meta">
                    CHAPTER {b.data.completedChapters} / {b.data.totalChapters} · 완료율 {pct}%
                  </span>
                </a>
                <p class="t-desc">{b.data.description}</p>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {matchedInsights.length > 0 && (
      <section class="topic-section">
        <h2>인사이트</h2>
        <ul class="topic-list">
          {matchedInsights.map((e) => (
            <li>
              <a href={insightUrl(e.slug)} class="no-underline">
                <span class="t-title">{e.data.title}</span>
                <span class="t-meta">
                  {formatKoreanDate(e.data.publishedAt)} · 1차 출처 {e.data.sources.length}건
                </span>
              </a>
              <p class="t-desc">{e.data.tldr}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {matchedPulses.length > 0 && (
      <section class="topic-section">
        <h2>최근 펄스</h2>
        <ul class="topic-list">
          {matchedPulses.slice(0, 10).map((e) => (
            <li>
              <a href={pulseUrl(e.slug, e.data.publishedAt)} class="no-underline">
                <span class="t-title">{e.data.title}</span>
                <span class="t-meta">
                  {formatKoreanDate(e.data.publishedAt)} · 1차 출처 {e.data.sources.length}건
                </span>
              </a>
              <p class="t-desc">{e.data.tldr}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {matchedChapters.length > 0 && (
      <section class="topic-section">
        <h2>가이드북 챕터</h2>
        <ul class="topic-list compact">
          {matchedChapters.map((c) => (
            <li>
              <a href={`/guidebook/${c.data.bookSlug}/${c.data.chapterNumber}/`} class="no-underline">
                <span class="t-num">CH {String(c.data.chapterNumber).padStart(2, '0')}</span>
                <span class="t-title">{c.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {totalItems === 0 && (
      <p class="topic-empty">아직 이 주제에 큐레이션된 글이 없습니다.</p>
    )}

    <footer class="topic-footer">
      <p>
        본 큐레이션은 펄스·인사이트·가이드북 컬렉션의 카테고리·제목 매칭으로 자동
        구성됩니다. 1차 출처 인용 그래프는 <a href="/data/">/data/</a> 에서 다운로드.
        편집 정책은 <a href="/methodology/">/methodology/</a>.
      </p>
    </footer>
  </main>

  <Footer />
</BaseLayout>

{chartPayload && (
  <script is:inline define:vars={{ chartPayload }}>
    function ready() { return typeof window !== 'undefined' && typeof window.Chart !== 'undefined'; }
    function init() {
      const ACCENT = '#8b1538';
      const INK_MUTE = '#707070';
      Chart.defaults.font.family = "'Pretendard Variable','Pretendard',system-ui,sans-serif";
      Chart.defaults.color = INK_MUTE;
      Chart.defaults.borderColor = '#cccccc';

      const canvas = document.getElementById(`topic-chart-${chartPayload.id}`);
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: chartPayload.labels,
          datasets: [{
            label: chartPayload.label,
            data: chartPayload.values,
            borderColor: ACCENT,
            backgroundColor: 'rgba(139, 21, 56, 0.08)',
            borderWidth: 1.5,
            pointRadius: 0,
            pointHoverRadius: 4,
            fill: true,
            tension: 0.18,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#1a1a1a',
              titleFont: { size: 11 },
              bodyFont: { size: 12 },
              padding: 8,
              callbacks: {
                label: function(item) {
                  return chartPayload.label + ': ' + Number(item.parsed.y).toLocaleString('ko-KR') + ' ' + chartPayload.unit;
                },
              },
            },
          },
          scales: {
            x: { grid: { display: false }, ticks: { font: { size: 10 }, maxTicksLimit: 8 } },
            y: { grid: { color: '#eaeaea', lineWidth: 0.5 }, ticks: { font: { size: 10 } } },
          },
        },
      });
    }
    if (ready()) init();
    else {
      let attempts = 0;
      const t = setInterval(() => {
        if (ready() || attempts++ > 60) { clearInterval(t); if (ready()) init(); }
      }, 100);
    }
  </script>
)}

<style>
  .topic-wrap {
    max-width: var(--width-page);
    margin: 0 auto;
    padding: 56px var(--width-gutter) 64px;
  }
  .topic-header {
    border-bottom: 0.5px solid var(--color-ink-quat);
    padding-bottom: 28px;
    margin-bottom: 36px;
    max-width: var(--width-prose);
  }
  .topic-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    margin-bottom: 14px;
  }
  .topic-title {
    font-family: var(--font-serif);
    font-size: 32px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 500;
    margin: 0 0 14px;
  }
  @media (max-width: 640px) {
    .topic-title { font-size: 26px; }
  }
  .topic-lead {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink-secondary);
    margin: 0;
  }
  /* ─── ECOS 시계열 차트 (ecosSeriesId 가 설정된 토픽) ─── */
  .topic-chart {
    border: 0.5px solid var(--color-ink-quat);
    padding: 22px 24px;
    margin-bottom: 36px;
  }
  .tc-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    align-items: start;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  @media (max-width: 720px) { .tc-head { grid-template-columns: 1fr; } }
  .tc-title {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 500;
    margin: 0 0 6px;
  }
  .tc-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-tertiary);
    margin: 0;
    letter-spacing: 0.04em;
    line-height: 1.5;
  }
  .tc-stats { display: flex; gap: 18px; flex-wrap: wrap; }
  .tc-stat { min-width: 80px; }
  .tc-stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-ink-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 2px;
  }
  .tc-stat-value {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 500;
  }
  .tc-stat-unit { font-size: 11px; color: var(--color-ink-tertiary); margin-left: 3px; font-weight: 400; }
  .tc-stat-meta { font-family: var(--font-mono); font-size: 10px; color: var(--color-ink-tertiary); margin-top: 2px; }
  .tc-delta-up { color: #a83a3a; }
  .tc-delta-down { color: #2a7a3a; }
  .tc-delta-flat { color: var(--color-ink-tertiary); }
  .tc-canvas-wrap { height: 220px; position: relative; }
  .tc-foot {
    margin: 12px 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-tertiary);
  }
  .tc-foot a { color: var(--color-link); }

  .topic-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 48px;
  }
  @media (max-width: 720px) {
    .topic-stats { grid-template-columns: 1fr; }
  }
  .topic-section {
    margin-bottom: 48px;
  }
  .topic-section :global(h2) {
    font-family: var(--font-serif);
    font-size: 22px;
    margin: 0 0 18px;
    padding-bottom: 8px;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .topic-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .topic-list li {
    padding: 14px 0;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .topic-list li:last-child { border-bottom: 0; }
  .topic-list a {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: inherit;
    margin-bottom: 6px;
  }
  .topic-list a:hover .t-title { color: var(--color-accent); }
  .t-title {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.45;
    color: var(--color-ink);
    transition: color 0.15s ease;
  }
  .t-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.04em;
  }
  .t-desc {
    font-size: 13px;
    color: var(--color-ink-secondary);
    line-height: 1.7;
    margin: 4px 0 0;
  }
  .topic-list.compact li {
    padding: 8px 0;
  }
  .topic-list.compact a {
    flex-direction: row;
    gap: 16px;
    align-items: baseline;
    margin-bottom: 0;
  }
  .topic-list.compact .t-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.06em;
    min-width: 56px;
  }
  .topic-list.compact .t-title { font-size: 15px; }
  .topic-empty {
    color: var(--color-ink-secondary);
    font-style: italic;
  }
  .topic-footer {
    border-top: 0.5px solid var(--color-ink-quat);
    padding-top: 24px;
    margin-top: 48px;
    font-size: 12px;
    color: var(--color-ink-tertiary);
    line-height: 1.7;
  }
</style>
