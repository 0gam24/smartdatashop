---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import BreadcrumbMasthead from '../components/BreadcrumbMasthead.astro';
import ArticleHeader from '../components/ArticleHeader.astro';
import TrustBar from '../components/TrustBar.astro';
import SourceList from '../components/SourceList.astro';
import AuthorCard from '../components/AuthorCard.astro';
import CorrectionsBlock from '../components/CorrectionsBlock.astro';
import Footer from '../components/Footer.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import CitationExport from '../components/CitationExport.astro';
import { categoryToKorean, formatKoreanDate, pulseDateParts, type Category } from '../lib/korean';
import { buildBreadcrumbLD, buildPersonLD } from '../lib/jsonld';

interface Source {
  name: string;
  url?: string;
  date?: string;
  accessedAt?: string;
  note?: string;
}

interface Correction {
  date: string;
  description: string;
}

interface Props {
  category: Category;
  publishedAt: string;
  updatedAt?: string;
  title: string;
  author?: string;
  readingTime: number;
  sources: Source[];
  aiAssisted: false | 'edit' | 'draft' | 'fact-check';
  vol?: string;
  no?: string;
  /** SEO/SNS 카드용 — 호출자가 전달하면 BaseLayout으로 그대로 전달된다. */
  description?: string;
  ogImage?: string;
  jsonld?: object | object[];
  /** 페이지 keywords meta — 페르소나/데이터유형/액션 태그 등에서 도출. */
  keywords?: string[];
  /** 정정 이력 — 비어 있으면 CorrectionsBlock은 렌더되지 않는다 */
  corrections?: Correction[];
  /**
   * true 일 때 robots noindex,nofollow 메타가 출력된다.
   * 동적 라우트가 placeholder 텍스트(`[검수 후 입력]` 등)를 검출했을 때
   * 색인 자동 차단용 — Layer 1 안전망. BaseLayout.noindex 로 그대로 전달.
   */
  noindex?: boolean;
}

const {
  category,
  publishedAt,
  updatedAt,
  title,
  author = '김준혁',
  readingTime,
  sources,
  aiAssisted,
  vol = 'I',
  no = '89',
  description,
  ogImage,
  jsonld,
  keywords,
  corrections = [],
  noindex = false,
} = Astro.props;

// 브레드크럼 표시용 날짜 (YYYY/MM/DD) — KST 기준
const { year: bcY, month: bcM, day: bcD } = pulseDateParts(publishedAt);
const breadcrumbDate = `${bcY}/${bcM}/${bcD}`;

// 헤더 우측 한국식 날짜
const headerDate = formatKoreanDate(publishedAt);

const pageTitle = `${title} — 스마트데이터샵`;

// ── BreadcrumbList JSON-LD 구성 ─────────────────────────────────────
// BreadcrumbMasthead의 시각적 트레일과 동일한 4단계:
//   홈 › 데일리 › {카테고리} › {YYYY/MM/DD}(현재)
// 검색엔진 위치 신호로 BreadcrumbList LD를 함께 발행한다.
// (NewsArticle LD 옆에 별도 블록으로 추가 — base layout이 배열을 받도록 정규화돼 있음)
const articleUrl = Astro.url.pathname; // /YYYY/MM/DD/slug/
const categoryLabel = categoryToKorean(category).replace(/ /g, '');
const breadcrumbItems = [
  { name: '홈', url: '/' },
  { name: '데일리', url: '/' },
  { name: categoryLabel, url: `/category/${category}/` },
  { name: breadcrumbDate, url: articleUrl },
];
const breadcrumbLd = buildBreadcrumbLD(breadcrumbItems);

// 호출자(jsonld prop)가 단일 객체 또는 배열을 줄 수 있다 — BreadcrumbList +
// Person LD (저자 E-E-A-T 신호) 를 항상 추가해 BaseLayout으로 통합 전달.
// 06 §3 E-E-A-T 저자 신호 / 07 §3 D.I.A. 저자 신뢰성.
const incomingJsonld = jsonld
  ? Array.isArray(jsonld)
    ? jsonld
    : [jsonld]
  : [];
const mergedJsonld: object[] = [...incomingJsonld, breadcrumbLd, buildPersonLD()];
---

<BaseLayout
  title={pageTitle}
  description={description}
  ogImage={ogImage}
  ogType="article"
  ogPublishedAt={publishedAt}
  ogModifiedAt={updatedAt ?? publishedAt}
  jsonld={mergedJsonld}
  keywords={keywords}
  noindex={noindex}
>
  <ReadingProgress />
  <Header activeNav="daily" date={headerDate} />
  <BreadcrumbMasthead category={category} dateText={breadcrumbDate} vol={vol} no={no} />

  <main id="main" role="main" class="article-wrap" data-screen-label="펄스 글">
    <ArticleTOC />

    <ArticleHeader
      category={category}
      publishedAt={publishedAt}
      title={title}
      author={author}
      readingTime={readingTime}
      sourceCount={sources.length}
      aiAssisted={aiAssisted}
      updatedAt={updatedAt}
    />

    <div class="article-body">
      <TrustBar
        aiAssisted={aiAssisted}
        sourceCount={sources.length}
        updatedAt={updatedAt ?? publishedAt}
        correctionsCount={corrections.length}
      />
      <slot />
      <AuthorCard name={author} />
      <CitationExport
        title={title}
        publishedAt={publishedAt}
        url={Astro.url.toString()}
        author={author}
      />
      <CorrectionsBlock corrections={corrections} />
      <hr />
      <SourceList sources={sources} />
    </div>

    <slot name="related" />
  </main>

  <Footer vol={vol} no={no} date={headerDate} />
</BaseLayout>

<style>
  .article-wrap {
    padding: 48px 0 64px;
  }
  .article-body {
    max-width: var(--width-prose);
    margin: 0 auto;
    padding: 0 var(--width-gutter);
  }
  .article-body :global(p) {
    margin-bottom: 1.4rem;
  }
  .article-body :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .article-body :global(hr) {
    border: 0;
    border-top: 0.5px solid var(--color-ink-quat);
    margin: 2rem 0;
  }
</style>

<!--
  MDX 각주 스타일링 결정 (작업 지시서 §"src/content/config.ts" 참조):
  remark-plugin을 추가하는 대신, Astro/MDX가 자동 생성하는
  `<sup>` (data-footnote-ref) 와 `<a>` 노드를 직접 셀렉터로 잡아
  `.fn` 글로벌 클래스의 시각적 효과를 재현한다. 이유는 (1) plugin 추가 없이
  설정 변경 없이 가능하고, (2) global.css 수정 금지 제약 안에서
  is:global 스타일 블록 하나로 해결되기 때문.
-->
<style is:global>
  /* MDX가 생성하는 각주 마커 — 스타일은 .fn 글로벌 클래스를 따라간다 */
  .article-body sup[data-footnote-ref],
  .article-body sup.footnote-ref {
    font-size: 10px;
    vertical-align: super;
    line-height: 0;
    margin: 0 1px;
  }
  .article-body sup[data-footnote-ref] a,
  .article-body sup.footnote-ref a {
    color: var(--color-accent);
    font-weight: 500;
    font-family: var(--font-sans);
    text-decoration: none;
  }

  /* MDX는 본문 끝에 <section data-footnotes>로 각주 정의 리스트를 자동 추가하는데,
     우리는 frontmatter sources를 SourceList로 따로 렌더하므로 자동 생성 섹션은 숨긴다. */
  .article-body section[data-footnotes] {
    display: none;
  }
</style>
