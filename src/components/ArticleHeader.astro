---
import { categoryToKorean, formatKoreanDate, formatKoreanTime, type Category } from '../lib/korean';
import VerifiedBadge from './VerifiedBadge.astro';
import BookmarkToggle from './BookmarkToggle.astro';

interface Props {
  category: Category;
  publishedAt: string;
  title: string;
  author: string;
  readingTime: number;
  sourceCount: number;
  aiAssisted: boolean;
  updatedAt?: string;
  /** 디자인 프리뷰 여부 — 검수 배지 표시 결정에 사용 */
  previewMode?: boolean;
  /** 검수 책임 운영자 아이디 목록 */
  verifiedBy?: string[];
}

const {
  category,
  publishedAt,
  title,
  author,
  readingTime,
  sourceCount,
  aiAssisted,
  updatedAt,
  previewMode = true,
  verifiedBy = [],
} = Astro.props;

// 정식 발행 = 명시적으로 previewMode가 꺼졌고, 검수 책임자가 1명 이상 등록된 경우
const isVerified = previewMode === false && verifiedBy.length >= 1;

const categoryLabel = categoryToKorean(category);
const dateLine = `${formatKoreanDate(publishedAt)} · ${formatKoreanTime(publishedAt)}`;

// 디자인 결정: H1은 평문 그대로 — 시안의 "[1]" sup은 데코레이션 마커이며,
// 본문 각주가 진짜 ref이므로 헤드라인을 단순화해 source-list 아키텍처와 일관성 유지.
// (작업 지시서 §11 참조)
---

<header class="article-header">
  <div class="article-meta-row">
    <span class="cat-label">{categoryLabel}</span>
    <time class="meta meta-time">{dateLine}</time>
  </div>
  <h1 class="article-headline">{title}</h1>
  <div class="article-byline">
    <span>{author}</span><span class="dot">·</span>
    <span>{readingTime}분 읽기</span><span class="dot">·</span>
    <span>1차 출처 {sourceCount}건</span>
    {updatedAt && (
      <>
        <span class="dot">·</span>
        <span>최종 갱신 {formatKoreanDate(updatedAt)}</span>
      </>
    )}
    {aiAssisted && <span class="ai-badge">AI 보조</span>}
    <VerifiedBadge verified={isVerified} verifiedBy={verifiedBy} />
    <span class="byline-spacer"></span>
    <BookmarkToggle />
  </div>
</header>

<style>
  .article-header {
    max-width: var(--width-prose);
    margin: 0 auto 32px;
    padding: 0 var(--width-gutter);
  }
  .article-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .meta-time {
    font-family: var(--font-serif);
  }
  .article-headline {
    font-family: var(--font-serif);
    font-size: 36px;
    line-height: 1.3;
    letter-spacing: -0.015em;
    font-weight: 500;
    margin-bottom: 18px;
  }
  @media (max-width: 640px) {
    .article-headline { font-size: 26px; }
  }
  .article-byline {
    font-size: 13px;
    color: var(--color-ink-secondary);
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  .byline-spacer {
    flex: 1 1 auto;
    min-width: 4px;
  }
</style>
