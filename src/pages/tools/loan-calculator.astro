---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { buildBreadcrumbLD } from '../../lib/jsonld';

const pageUrl = 'https://smartdatashop.kr/tools/loan-calculator/';
const title = '대출 원리금균등상환 계산기 — 월 상환액·총이자 계산';
const description =
  '대출 원금·이자율·기간을 입력하면 원리금균등·원금균등 상환의 월 상환액, 총이자, 총상환액을 즉시 계산합니다. 거치기간·중도상환·변동금리까지 실무 해설과 함께 제공하는 무료 대출 계산기.';

// WebApplication + FAQPage + HowTo + Breadcrumb 구조화 데이터
const faqItems = [
  {
    q: '원리금균등상환과 원금균등상환은 무엇이 다른가요?',
    a: '원리금균등상환은 매달 갚는 금액(원금+이자)이 처음부터 끝까지 같은 방식입니다. 원금균등상환은 매달 갚는 원금이 같고 이자는 잔액이 줄면서 함께 줄어, 초기 상환액이 크고 갈수록 작아집니다. 총이자는 대체로 원금균등이 더 적지만 초기 부담이 큽니다.',
  },
  {
    q: '대출 계산기의 월 상환액은 어떻게 계산되나요?',
    a: '원리금균등상환의 월 상환액 M은 원금 P, 월이자율 r(연이율/12), 개월수 n에 대해 M = P × r(1+r)ⁿ ÷ ((1+r)ⁿ − 1) 공식으로 계산합니다. 이 계산기는 이 공식으로 월 상환액을, 그리고 총 상환액에서 원금을 빼 총이자를 산출합니다.',
  },
  {
    q: '거치기간이 있으면 상환액이 어떻게 달라지나요?',
    a: '거치기간에는 원금을 갚지 않고 이자만 냅니다. 그래서 거치 중 월 납입액은 원금×월이자율로 작지만, 원금이 그대로 남아 거치가 끝난 뒤의 월 상환액과 총이자가 더 커집니다. 이 계산기는 거치개월을 입력하면 거치 후 기간으로 원금을 나눠 계산합니다.',
  },
  {
    q: '중도상환수수료는 계산에 포함되나요?',
    a: '이 계산기는 약정대로 만기까지 상환하는 것을 기준으로 계산하며 중도상환수수료는 포함하지 않습니다. 실제로 대출을 미리 갚으면 남은 기간에 비례해 중도상환수수료(보통 대출 후 3년 이내)가 부과될 수 있으므로, 상품 약관을 별도로 확인해야 합니다.',
  },
  {
    q: '변동금리 대출도 이 계산기로 정확히 계산되나요?',
    a: '변동금리는 기준금리 변동에 따라 이자율이 바뀌므로, 이 계산기의 고정 이율 결과는 현재 금리 기준의 추정치입니다. 금리가 오르면 실제 상환액은 늘어납니다. 변동금리 대출은 금리 상승 시나리오(예: +1%p)를 함께 입력해 부담 범위를 가늠하는 것이 안전합니다.',
  },
];

const howToLD = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '대출 계산기 사용 방법',
  description: '대출 원금·이자율·기간을 입력해 월 상환액과 총이자를 계산하는 방법.',
  step: [
    { '@type': 'HowToStep', name: '원금 입력', text: '대출 원금을 만원 단위로 입력합니다. 예: 3억이면 30000.' },
    { '@type': 'HowToStep', name: '이자율 입력', text: '연 이자율을 퍼센트로 입력합니다. 예: 4.0.' },
    { '@type': 'HowToStep', name: '기간·방식 선택', text: '대출 기간(년)과 상환 방식(원리금균등/원금균등)을 고릅니다.' },
    { '@type': 'HowToStep', name: '결과 확인', text: '월 상환액, 총이자, 총상환액이 자동으로 계산됩니다.' },
  ],
};

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: '대출 원리금균등상환 계산기',
    url: pageUrl,
    description,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web (모든 브라우저)',
    browserRequirements: 'Requires JavaScript',
    inLanguage: 'ko-KR',
    isAccessibleForFree: true,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'KRW' },
    provider: {
      '@type': 'Organization',
      name: '스마트데이터샵',
      url: 'https://smartdatashop.kr/',
    },
  },
  howToLD,
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  buildBreadcrumbLD([
    { name: '홈', url: '/' },
    { name: '대출 원리금균등상환 계산기', url: '/tools/loan-calculator/' },
  ]),
];
---

<BaseLayout title={`${title} — 스마트데이터샵`} description={description} jsonld={jsonld}>
  <Header />

  <main id="main" class="tool-wrap">
    <header class="tool-head">
      <div class="tool-eyebrow">도 구 · 금 융 계 산 기</div>
      <h1 class="tool-title">대출 원리금균등상환 계산기</h1>
      <p class="tool-sub">
        원금·이자율·기간을 입력하면 <strong>월 상환액·총이자·총상환액</strong>을 즉시 계산합니다.
        원리금균등·원금균등, 거치기간까지 반영하는 무료 대출 계산기입니다.
      </p>
    </header>

    <!-- ① 인터랙티브 계산기 (폴드 상단) -->
    <section class="calc" aria-label="대출 상환 계산기">
      <div class="calc-inputs">
        <div class="field">
          <label for="c-principal">대출 원금 <span class="unit">(만원)</span></label>
          <input id="c-principal" type="number" inputmode="numeric" min="0" step="100" value="30000" aria-label="대출 원금 (만원)" />
          <div class="hint" id="c-principal-hint">3억 원</div>
        </div>
        <div class="field">
          <label for="c-rate">연 이자율 <span class="unit">(%)</span></label>
          <input id="c-rate" type="number" inputmode="decimal" min="0" step="0.01" value="4.0" aria-label="연 이자율 (%)" />
        </div>
        <div class="field">
          <label for="c-term">대출 기간 <span class="unit">(년)</span></label>
          <input id="c-term" type="number" inputmode="numeric" min="1" max="50" step="1" value="30" aria-label="대출 기간 (년)" />
        </div>
        <div class="field">
          <label for="c-grace">거치기간 <span class="unit">(개월, 선택)</span></label>
          <input id="c-grace" type="number" inputmode="numeric" min="0" step="1" value="0" aria-label="거치기간 (개월)" />
        </div>
        <div class="field field-full">
          <span class="field-legend">상환 방식</span>
          <div class="radio-row" role="radiogroup" aria-label="상환 방식">
            <label class="radio"><input type="radio" name="c-method" value="equal-payment" checked /> 원리금균등</label>
            <label class="radio"><input type="radio" name="c-method" value="equal-principal" /> 원금균등</label>
          </div>
        </div>
      </div>

      <div class="calc-results" aria-live="polite">
        <div class="result-main">
          <div class="result-label" id="c-main-label">월 상환액</div>
          <div class="result-value" id="c-monthly">–</div>
        </div>
        <div class="result-grid">
          <div class="result-cell">
            <div class="result-label">총 이자</div>
            <div class="result-sub" id="c-interest">–</div>
          </div>
          <div class="result-cell">
            <div class="result-label">총 상환액</div>
            <div class="result-sub" id="c-total">–</div>
          </div>
          <div class="result-cell">
            <div class="result-label">상환 개월</div>
            <div class="result-sub" id="c-months">–</div>
          </div>
        </div>
        <p class="calc-note" id="c-note"></p>
      </div>
    </section>
    <p class="calc-disclaimer">
      ※ 계산 결과는 입력값 기준 <strong>추정치</strong>이며, 실제 대출은 우대금리·중도상환수수료·상환일 등에 따라 달라질 수 있습니다.
    </p>

    <!-- ② 공식 및 원리 (중간 레이어 — 전문성) -->
    <section class="tool-body">
      <h2>원리금균등상환이란 — 계산 공식과 원리</h2>
      <p>
        원리금균등상환은 대출 기간 내내 <strong>매달 갚는 금액(원금+이자)이 동일</strong>한 상환 방식입니다.
        초반에는 갚는 돈 중 이자 비중이 크고 원금 비중이 작지만, 회차가 지날수록 원금 비중이 커집니다.
        월 상환액은 다음 공식으로 계산합니다.
      </p>

      <figure class="formula" aria-label="원리금균등상환 월 상환액 공식">
        <div class="formula-eq">
          <span class="f-var">M</span>
          <span class="f-op">=</span>
          <span class="f-var">P</span>
          <span class="f-op">×</span>
          <span class="f-frac">
            <span class="f-num">r (1 + r)<sup>n</sup></span>
            <span class="f-den">(1 + r)<sup>n</sup> − 1</span>
          </span>
        </div>
        <figcaption>
          <strong>M</strong> = 월 상환액 · <strong>P</strong> = 대출 원금 · <strong>r</strong> = 월이자율(연이율÷12) · <strong>n</strong> = 총 상환 개월수
        </figcaption>
      </figure>

      <p>
        예를 들어 원금 1억 원(P), 연이율 4%(월이자율 r ≈ 0.00333), 20년(n = 240개월)이라면 위 공식으로 월 상환액이 정해집니다.
        총이자는 <span class="mono">월 상환액 × 개월수 − 원금</span>으로 구하며, 이 계산기는 정확히 이 방식으로 산출합니다.
        월이자율이 0인 경우(무이자)에는 <span class="mono">M = P ÷ n</span>으로 단순화됩니다.
      </p>

      <h2>원리금균등 vs 원금균등 — 무엇을 고를까</h2>
      <p>
        두 방식의 차이는 '매달 같은 것'이 무엇이냐에 있습니다. 원리금균등은 <strong>총 납입액</strong>이 매달 같고,
        원금균등은 <strong>갚는 원금</strong>이 매달 같습니다. 아래 표로 정리했습니다.
      </p>
      <table class="cmp">
        <thead>
          <tr><th>구분</th><th>원리금균등</th><th>원금균등</th></tr>
        </thead>
        <tbody>
          <tr><td>매달 같은 것</td><td>총 상환액</td><td>갚는 원금</td></tr>
          <tr><td>초기 부담</td><td>일정</td><td>큼(점차 감소)</td></tr>
          <tr><td>총이자</td><td>상대적 많음</td><td>상대적 적음</td></tr>
          <tr><td>적합한 사람</td><td>일정 관리 선호</td><td>초기 여력 있음</td></tr>
        </tbody>
      </table>
      <p>
        같은 조건이라면 총이자는 대체로 원금균등이 더 적습니다. 원금을 초반부터 빠르게 줄여 이자가 붙는 잔액이 작아지기 때문입니다.
        다만 원금균등은 첫 회차 상환액이 가장 커서 초기 현금 부담이 큽니다. 위 계산기에서 <strong>상환 방식을 바꿔 가며</strong>
        두 방식의 월 상환액과 총이자를 직접 비교해 보면, 본인 현금흐름에 맞는 선택이 분명해집니다.
      </p>

      <h2>거치기간이 있으면 어떻게 되나</h2>
      <p>
        거치기간은 <strong>원금을 갚지 않고 이자만 내는 기간</strong>입니다. 거치 중에는 월 납입액이 '원금 × 월이자율'로 작아져
        당장의 부담이 가볍습니다. 하지만 그동안 원금이 전혀 줄지 않으므로, 거치가 끝난 뒤에는 남은 짧은 기간에 원금을 몰아 갚게 돼
        월 상환액이 커지고 총이자도 늘어납니다. 계산기의 <span class="mono">거치기간(개월)</span>에 값을 넣으면,
        거치 후 기간으로 원금을 나눠 상환액을 다시 계산합니다. 거치는 '지금 편하지만 나중에 무거워지는' 선택이라는 점을 수치로 확인할 수 있습니다.
      </p>

      <h2>중도상환수수료 — 미리 갚을 때</h2>
      <p>
        대출을 약정보다 일찍 갚으면 은행이 <strong>중도상환수수료</strong>를 물릴 수 있습니다. 보통 대출 실행 후 3년 이내에
        남은 기간에 비례해 부과되며, 3년이 지나면 면제되는 경우가 많습니다. 이 계산기는 만기까지 정상 상환을 기준으로 하므로
        중도상환수수료는 포함하지 않습니다. 여윳돈으로 원금을 미리 갚아 이자를 줄이려 할 때는, 줄어드는 이자와 물어야 할 수수료를
        함께 비교해 실익을 따지는 것이 좋습니다.
      </p>

      <h2>변동금리 대출은 금리 상승을 함께 보라</h2>
      <p>
        고정금리는 만기까지 이자율이 그대로지만, 변동금리는 기준금리에 따라 주기적으로 이자율이 바뀝니다. 그래서 변동금리 대출의
        상환액은 '지금 금리 기준의 추정치'일 뿐입니다. 금리가 오르면 월 상환액도 함께 오릅니다. 변동금리라면 이 계산기에
        <strong>현재 금리와 +1%p·+2%p 시나리오를 각각 입력</strong>해 부담이 어디까지 커질 수 있는지 미리 가늠해 두는 것이 안전합니다.
        정책 대출의 금리 환경은 <a href="/2026/06/12/2026-06-12-mortgage-rate-hike-outlook/">주담대 금리 인상 전망 글</a>에서 다뤘습니다.
      </p>

      <h2>실제 시나리오 — 정책 대출에 대입하기</h2>
      <p>
        이 계산기는 어떤 대출에도 쓸 수 있지만, 특히 금리·한도가 정해진 정책 대출에 대입하면 상환 계획을 세우기 좋습니다.
        예를 들어 내 집 마련용 <a href="/2026/06/23/2026-06-23-didimdol-home-loan-2026/">디딤돌 대출</a>이나
        전세 자금용 <a href="/2026/06/22/2026-06-22-jeonse-loan-beotimmok-2026/">버팀목 전세자금대출</a>의 금리·한도를
        위 입력창에 넣으면, 매달 얼마를 갚아야 하고 총이자가 얼마인지 즉시 확인할 수 있습니다. 신생아 특례나 청년 전용 상품도
        마찬가지로, 상품별 금리를 바꿔 넣어 가며 총부담을 비교하면 '어떤 대출이 내게 유리한지'가 숫자로 드러납니다.
        7월의 세금·대출 등 돈 일정 전체는 <a href="/insight/2026-06-12-july-2026-money-calendar/">7월 머니 캘린더</a>에서 함께 볼 수 있습니다.
      </p>

      <h2>이 계산기의 계산 방식</h2>
      <p>
        투명성을 위해 계산 방식을 밝힙니다. 월 상환액은 위의 원리금균등 공식(또는 원금균등의 경우 회차별 잔액에 월이자율을 곱해 합산)으로
        계산하며, 모든 연산은 <strong>브라우저에서 즉시 처리</strong>됩니다. 입력값은 서버로 전송·저장되지 않습니다. 결과는 원 단위로
        반올림해 표시하므로 실제 상환표와 1원 단위 차이가 있을 수 있고, 우대금리·상환일·수수료 등 상품별 조건은 반영되지 않은 추정치입니다.
        정확한 상환표는 실행 은행의 대출 약정서를 기준으로 확인하시기 바랍니다.
      </p>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        <div class="faq-item">
          <h3>Q. 원리금균등상환과 원금균등상환은 무엇이 다른가요?</h3>
          <p>
            원리금균등상환은 매달 갚는 금액(원금+이자)이 처음부터 끝까지 같습니다. 원금균등상환은 매달 갚는 원금이 같고 이자는
            잔액이 줄면서 함께 줄어, 초기 상환액이 크고 갈수록 작아집니다. 총이자는 대체로 원금균등이 더 적지만 초기 부담이 큽니다.
          </p>
        </div>
        <div class="faq-item">
          <h3>Q. 월 상환액은 어떻게 계산되나요?</h3>
          <p>
            원리금균등상환의 월 상환액 M은 원금 P, 월이자율 r(연이율÷12), 개월수 n에 대해
            <span class="mono">M = P × r(1+r)ⁿ ÷ ((1+r)ⁿ − 1)</span> 공식으로 계산합니다. 총이자는 총 상환액에서 원금을 뺀 값입니다.
          </p>
        </div>
        <div class="faq-item">
          <h3>Q. 거치기간을 넣으면 왜 총이자가 늘어나나요?</h3>
          <p>
            거치기간에는 원금을 갚지 않고 이자만 내므로, 그동안 원금이 줄지 않습니다. 원금이 그대로 남은 채 시간이 흐르면 그만큼
            이자가 더 붙고, 거치 후 짧은 기간에 원금을 갚느라 월 상환액도 커집니다.
          </p>
        </div>
        <div class="faq-item">
          <h3>Q. 이 계산기 결과를 그대로 믿어도 되나요?</h3>
          <p>
            입력값 기준의 추정치로 참고용입니다. 우대금리·중도상환수수료·상환일 등 상품별 조건이 반영되지 않으므로, 실제 상환액은
            은행 대출 약정서를 기준으로 확인해야 합니다. 특히 변동금리는 금리가 오르면 상환액이 늘어납니다.
          </p>
        </div>
      </div>
    </section>
  </main>

