---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { containsUnresolvedToken } from '../lib/placeholder';
import { buildWebPageLD, buildBreadcrumbLD } from '../lib/jsonld';

interface Props {
  title: string;
  description?: string;
  /** 페이지 상단 카테고리 라벨 — 예: "정 책 페 이 지" */
  eyebrow?: string;
  /** 마지막 갱신일 — 문자열 그대로 노출 */
  updatedAt?: string;
  /** OG 이미지 절대 URL — author 페이지처럼 페이지별 카드를 쓸 때 명시 */
  ogImage?: string;
  /** JSON-LD (단일/배열) — 미지정 시 자동 WebPage + Breadcrumb LD fallback */
  jsonld?: object | object[];
  /** 명시적 noindex 강제 (자동 검출과 OR). 페이지가 의도적으로 비공개일 때 사용. */
  noindex?: boolean;
}

const {
  title,
  description,
  eyebrow = '정 책',
  updatedAt,
  ogImage,
  jsonld,
  noindex: forceNoindex = false,
} = Astro.props;

// 모든 정책 페이지에 baseline LD 보장 — 호출자가 jsonld 명시 안 했을 때만 자동 적용.
// (편집/AI/약관/개인정보/연락처/제휴/정정 등 — Ralph 회차 17 회귀 가드 fallback)
const pagePath = Astro.url.pathname;
const fallbackLd = jsonld
  ? jsonld
  : [
      buildWebPageLD(title, description ?? title),
      buildBreadcrumbLD([
        { name: '홈', url: '/' },
        { name: title, url: pagePath },
      ]),
    ];

// Layer 3 자동 noindex (Risk #1, ADR 0005):
// 본문 슬롯에 `[TODO: 운영자 작성]` / `[검수 후 ...]` 류 미완성 토큰이 존재하면
// Discover/Search 색인 차단. 운영자가 본문을 채우면 자동 색인 복귀.
const slotHtml = await Astro.slots.render('default');
const autoNoindex = containsUnresolvedToken(slotHtml);
const noindex = forceNoindex || autoNoindex;
---

<BaseLayout
  title={`${title} — 스마트데이터샵`}
  description={description ?? title}
  ogImage={ogImage}
  jsonld={fallbackLd}
  noindex={noindex}
>
  <Header />

  <main id="main" role="main" class="policy-wrap">
    <header class="policy-header">
      <div class="policy-eyebrow">{eyebrow}</div>
      <h1 class="policy-title">{title}</h1>
      {updatedAt && <p class="policy-updated">마지막 갱신: {updatedAt}</p>}
    </header>

    <article class="policy-body" set:html={slotHtml}></article>
  </main>

  <Footer vol="I" no="89" />
</BaseLayout>

<style>
  .policy-wrap {
    max-width: var(--width-prose);
    margin: 0 auto;
    padding: 56px var(--width-gutter) 64px;
  }
  @media (max-width: 640px) {
    .policy-wrap { padding: 40px var(--width-gutter) 48px; }
  }

  .policy-header {
    border-bottom: 0.5px solid var(--color-ink-quat);
    padding-bottom: 18px;
    margin-bottom: 36px;
  }
  .policy-eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--color-ink-secondary);
    margin-bottom: 12px;
  }
  .policy-title {
    font-family: var(--font-serif);
    font-size: 32px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 500;
    margin: 0;
  }
  @media (max-width: 640px) {
    .policy-title { font-size: 26px; }
  }
  .policy-updated {
    margin: 12px 0 0;
    font-size: 12px;
    color: var(--color-ink-tertiary);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }

  .policy-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.4;
    letter-spacing: -0.005em;
    font-weight: 500;
    margin: 2.5rem 0 1rem;
  }
  .policy-body :global(h3) {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.5;
    margin: 1.75rem 0 0.5rem;
  }
  .policy-body :global(p) {
    margin: 0 0 1.25rem;
    line-height: 1.85;
  }
  .policy-body :global(ul),
  .policy-body :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }
  .policy-body :global(li) { margin-bottom: 0.35rem; }
  .policy-body :global(.todo) {
    display: block;
    border: 0.5px solid var(--color-accent-soft);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 12px 16px;
    margin: 1rem 0 1.5rem;
    font-size: 13px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }
  .policy-body :global(.meta-table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    font-size: 14px;
  }
  .policy-body :global(.meta-table th),
  .policy-body :global(.meta-table td) {
    text-align: left;
    padding: 10px 12px;
    border-bottom: 0.5px solid var(--color-ink-quat);
    vertical-align: top;
  }
  .policy-body :global(.meta-table th) {
    width: 30%;
    font-weight: 500;
    color: var(--color-ink-secondary);
    font-size: 13px;
    letter-spacing: 0.02em;
  }
</style>
