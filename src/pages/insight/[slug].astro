---
/**
 * 인사이트 상세 — /insight/[slug]/
 *
 * 레이아웃 결정: ArticleLayout 대신 InsightLayout 사용.
 *   - ArticleLayout은 Header activeNav="daily"와 BreadcrumbMasthead("데일리" 하드코딩)를
 *     사용하므로 인사이트에서 그대로 쓰면 네비게이션이 펄스로 잘못 표시된다.
 *   - InsightLayout은 ArticleLayout의 prose 골격(같은 ArticleHeader, SourceList,
 *     related slot, --width-prose, MDX 각주 처리)을 보존하면서 헤더/브레드크럼만 인사이트용으로 교체.
 *   - 펄스의 "원문 →" ToollGate 의례는 인사이트 본문 자체가 심층 분석이므로 강제하지 않는다
 *     (필요시 본문 MDX에서 직접 호출 가능).
 *
 * estimatedReadingTime은 frontmatter 필수값이므로 본문 길이 추정 대신 그 값을 그대로 사용.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import InsightLayout from '../../layouts/InsightLayout.astro';
import Tldr from '../../components/Tldr.astro';
import RelatedList from '../../components/RelatedList.astro';
import { insightUrl, pulseDateParts } from '../../lib/korean';

export async function getStaticPaths() {
  const entries = await getCollection('insight');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'insight'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

// 관련 글 — 같은 카테고리 다른 인사이트 우선, 부족하면 최신 인사이트로 보충, 최대 3건
const allInsights = await getCollection('insight');
const others = allInsights.filter((e) => e.slug !== entry.slug);

const sameCategory = others
  .filter((e) => e.data.category === data.category)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const fallback = others
  .filter((e) => e.data.category !== data.category)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const relatedEntries = [...sameCategory, ...fallback].slice(0, 3);
const related = relatedEntries.map((e) => {
  const { year, month, day } = pulseDateParts(e.data.publishedAt);
  return {
    when: `${year}.${month}.${day}`,
    title: e.data.title,
    href: insightUrl(e.slug),
  };
});

// 페이지 keywords meta — Naver C-Rank/D.I.A. 신호로 페르소나·데이터유형·액션 태그를 합쳐 노출.
const keywords = [
  ...data.tags.personas,
  ...data.tags.dataTypes,
  ...data.tags.actions,
];

// 명시적 coverImage 가 없으면 동적 OG 카드(/og/insight/<slug>.png)로 자동 폴백.
const ogImage = data.coverImage
  ? data.coverImage.startsWith('http')
    ? data.coverImage
    : `https://smartdatashop.kr${data.coverImage}`
  : `https://smartdatashop.kr/og/insight/${entry.slug}.png`;
---

<InsightLayout
  category={data.category}
  publishedAt={data.publishedAt}
  updatedAt={data.updatedAt}
  title={data.title}
  readingTime={data.estimatedReadingTime}
  sources={data.sources}
  aiAssisted={data.aiAssisted}
  previewMode={data.previewMode}
  verifiedBy={data.verifiedBy}
  corrections={data.correctionLog}
  keywords={keywords}
  ogImage={ogImage}
>
  <Tldr>{data.tldr}</Tldr>
  <Content />

  {related.length > 0 && (
    <Fragment slot="related">
      <RelatedList items={related} />
    </Fragment>
  )}
</InsightLayout>
