---
import PolicyLayout from '../layouts/PolicyLayout.astro';
import { getCollection } from 'astro:content';
import { pulseUrl, insightUrl, formatKoreanDate } from '../lib/korean';

// 모든 콜렉션의 correctionLog를 모아 시간순으로 정렬한다.
const allPulses = await getCollection('pulse');
const allInsights = await getCollection('insight');

interface CorrectionEntry {
  date: string;
  description: string;
  href: string;
  title: string;
  collection: 'pulse' | 'insight';
}

const corrections: CorrectionEntry[] = [];

for (const e of allPulses) {
  for (const c of e.data.correctionLog ?? []) {
    corrections.push({
      ...c,
      href: pulseUrl(e.slug, e.data.publishedAt),
      title: e.data.title,
      collection: 'pulse',
    });
  }
}
for (const e of allInsights) {
  for (const c of e.data.correctionLog ?? []) {
    corrections.push({
      ...c,
      href: insightUrl(e.slug),
      title: e.data.title,
      collection: 'insight',
    });
  }
}

corrections.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<PolicyLayout
  title="정정 이력"
  eyebrow="정 책 · C O R R E C T I O N S"
  description="발행 후 발견된 사실·수치 오류 정정 이력 통합 페이지."
>
  <p>본 사이트는 발행 후 사실·수치 오류가 확인되면 본문 하단에 정정 이력을 기록하고, 본 페이지에 통합합니다. 정정 절차는 <a href="/editorial-policy/">/editorial-policy/</a> 참조.</p>

  {corrections.length === 0 ? (
    <>
      <p class="todo">아직 정정 이력이 없습니다. 정정 사례가 발생하면 본 페이지가 자동으로 갱신됩니다.</p>
      <p class="todo">[TODO: 운영자 작성] — 정정 요청 안내문 (이메일 / 양식). 운영자 본인 어조로 작성.</p>
    </>
  ) : (
    <ul>
      {corrections.map((c) => (
        <li>
          <strong>{formatKoreanDate(c.date)}</strong> — <a href={c.href}>{c.title}</a><br />
          <span style="color:var(--color-ink-secondary);font-size:14px;">{c.description}</span>
        </li>
      ))}
    </ul>
  )}
</PolicyLayout>
