---
/**
 * Sparkline — 본문 inline 미니 라인 차트. 의존성 0, 순수 SVG.
 *
 * 사용 예:
 *   <Sparkline values={[100, 102, 99, 105, 110, 108, 115]} ariaLabel="가계대출 5개월 추이" />
 */
interface Props {
  values: number[];
  width?: number;
  height?: number;
  stroke?: string;
  /** WCAG — 무한 스크롤 형 데이터 시각화에 필수 */
  ariaLabel: string;
}

const {
  values,
  width = 120,
  height = 32,
  stroke = 'var(--color-accent)',
  ariaLabel,
} = Astro.props;

const min = Math.min(...values);
const max = Math.max(...values);
const range = max - min || 1;
const stepX = values.length > 1 ? width / (values.length - 1) : 0;
const points = values
  .map((v, i) => {
    const x = i * stepX;
    const y = height - ((v - min) / range) * height;
    return `${x.toFixed(2)},${y.toFixed(2)}`;
  })
  .join(' ');
const lastIdx = values.length - 1;
const lastX = lastIdx * stepX;
const lastY = height - ((values[lastIdx] - min) / range) * height;
---

<svg
  class="sparkline"
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  role="img"
  aria-label={ariaLabel}
>
  <polyline points={points} fill="none" stroke={stroke} stroke-width="1.5" />
  <circle cx={lastX} cy={lastY} r="2" fill={stroke} />
</svg>

<style>
  .sparkline {
    display: inline-block;
    vertical-align: middle;
    overflow: visible;
  }
</style>
