---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Masthead from '../components/Masthead.astro';
import Hero from '../components/Hero.astro';
import EconomyChart from '../components/EconomyChart.astro';
import TodayDataDigest from '../components/TodayDataDigest.astro';
import SectionHead from '../components/SectionHead.astro';
import PulseList from '../components/PulseList.astro';
import PulseCard from '../components/PulseCard.astro';
import CategoryStrip from '../components/CategoryStrip.astro';
import CategoryColumn from '../components/CategoryColumn.astro';
import GuidebookCard from '../components/GuidebookCard.astro';
import ComingSoon from '../components/ComingSoon.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import Footer from '../components/Footer.astro';
import { categoryToKorean, formatKoreanTime, pulseUrl, pulseDateParts, kstTodayIso, type Category } from '../lib/korean';
import {
  buildOrganizationLD,
  buildPersonLD,
  buildSearchActionLD,
} from '../lib/jsonld';
import { getTodaySignals, getEcosHeroSpotlight } from '../lib/today-signals';

// 섹션 02 — 오늘의 펄스 5편 (content collection 기반)
const allPulses = await getCollection('pulse');
const allInsights = await getCollection('insight');
const allChapters = await getCollection('guidebookChapter');
const sortedPulses = allPulses.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
);
const latest = sortedPulses[0];

// Masthead 자동 집계 — 오늘의 글 (KST 기준 publishedAt 가 오늘) + 누적
const todayIso = kstTodayIso();
const todayPulseCount = allPulses.filter((e) =>
  e.data.publishedAt.startsWith(todayIso),
).length;
const todayInsightCount = allInsights.filter((e) =>
  e.data.publishedAt.startsWith(todayIso),
).length;
const todayChapterCount = allChapters.filter((e) =>
  e.data.publishedAt.startsWith(todayIso),
).length;
const todayCount = todayPulseCount + todayInsightCount + todayChapterCount;
const totalCount = allPulses.length + allInsights.length + allChapters.length;

// 발행 0편이어도 메인이 살아있음을 보이는 멀티시그널 — 24h 윈도우 SSOT 데이터 갱신 +
// 검수 대기 펄스 초안 갯수 (Plan 안 P0-1 — Discover/D.I.A. 신선도 신호 보강).
const todaySignals = getTodaySignals();

// 발행 0편 day = 자매 섹션 prominence 자동 상승 (Plan 안 P1-2).
// NETWORK.md §2.3: "메인은 자매 funnel hub" — 자매 트래픽 합산이 정체성.
// 펄스 발행이 끊긴 날 자매 cross-link funnel 의 비중을 높여 메인 hub 역할 유지.
const isQuietDay = todayCount === 0;

// Hero 우측 spotlight — ECOS |Δ%| 가장 큰 1종 (Plan 안 P2 priority 4):
// 펄스 hero + 데이터 spotlight 병기 = 발행 stale 한 날에도 신선도 신호 유지.
// fail-soft: ecos-timeseries.json 없거나 |Δ| 0 이면 null → Hero 의 hasChart 가
// 자동으로 차트 영역 미렌더 (안전 기본값).
const ecosSpotlight = getEcosHeroSpotlight();
const pulseCards = sortedPulses.slice(0, 5).map((entry) => {
  const { personas, dataTypes, actions } = entry.data.tags;
  const tags = [
    ...personas.map((label) => ({ label, group: 'persona' as const })),
    ...dataTypes.map((label) => ({ label, group: 'data-type' as const })),
    ...actions.map((label) => ({ label, group: 'action' as const, action: true })),
  ].slice(0, 3);
  return {
    category: categoryToKorean(entry.data.category),
    time: formatKoreanTime(entry.data.publishedAt),
    title: entry.data.title,
    tldr: entry.data.tldr,
    href: pulseUrl(entry.slug, entry.data.publishedAt),
    tags,
    coverImage: entry.data.coverImage,
  };
});

// 섹션 03 — 카테고리별 최신 (콘텐츠 컬렉션 기반)
//
// 편집 무결성 리팩토링 (Critical 3): 기존엔 5개 카테고리 × 3건 = 15건이
// 모두 가공된 헤드라인이었다 ("청년월세 특별지원 6월 마감, 잔여 예산 38%"
// 등). 사이트가 검수 전 디자인 샘플 단계라는 것을 독자에게 알리기 위해서는
// 홈에서도 실제 펄스 컬렉션의 글만 노출해야 한다. 카테고리에 글이 0건이면
// 빈 컬럼을 그대로 표시 — 그것 자체가 "아직 다루지 않은 분야"라는 정직한
// 신호다.
const CATEGORY_ORDER: Category[] = ['policy', 'tax-finance', 'market', 'stats', 'ai-tech'];
const groupedByCategory: Record<Category, typeof allPulses> = {
  policy: [],
  'tax-finance': [],
  market: [],
  stats: [],
  'ai-tech': [],
};
for (const e of allPulses) {
  groupedByCategory[e.data.category].push(e);
}

// 카테고리별 출처 라벨 — 펄스 첫 sources[0].name 에서 핵심 키워드 추출.
// 예: "통계청 4월 소비자물가동향" → "통계청"
function shortSourceName(fullName: string | undefined): string {
  if (!fullName) return '';
  const m = fullName.match(/^([^\s,(『「⌜]+)/);
  return m ? m[1] : fullName.slice(0, 8);
}

const categories = CATEGORY_ORDER.map((cat) => {
  const entriesInCat = groupedByCategory[cat]
    .slice()
    .sort(
      (a, b) =>
        new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
    );
  const items = entriesInCat.slice(0, 3).map((e, i) => {
    const { month, day } = pulseDateParts(e.data.publishedAt);
    const src = shortSourceName(e.data.sources[0]?.name);
    return {
      num: String(i + 1).padStart(2, '0'),
      title: e.data.title,
      meta: src ? `${month}.${day} · ${src}` : `${month}.${day}`,
      href: pulseUrl(e.slug, e.data.publishedAt),
    };
  });
  return {
    category: categoryToKorean(cat),
    count: `${entriesInCat.length}편`,
    items,
  };
});

// 섹션 04 — 진행 중인 가이드북 (컬렉션 기반).
// guidebook 컬렉션이 비어 있는 동안에는 섹션 자체를 렌더하지 않음.
// "준비 중" 정직 신호 — 운영자가 첫 가이드북 추가 시 자동 노출.
// (Eng #2, ADR 0005 — 편집 무결성: index.astro 에 가짜 데이터 박지 않는다)
const guidebooksCollection = await getCollection('guidebook').catch(() => []);
const guidebooks = guidebooksCollection
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 2)
  .map((entry) => {
    const totalCh = entry.data.totalChapters;
    const doneCh = entry.data.completedChapters;
    const pct = totalCh > 0 ? Math.round((doneCh / totalCh) * 100) : 0;
    const slug = entry.id.replace(/\.json$/, '');
    return {
      coverNum: entry.data.title.split(/\s+/)[0] ?? '·',
      coverTitle: entry.data.title,
      title: entry.data.title,
      description: entry.data.description,
      progressPct: pct,
      progressMeta: `CHAPTER ${doneCh} / ${totalCh} · 완료율 ${pct}%`,
      nextChapter: '',
      nextDate: '',
      href: `/guidebook/${slug}/`,
    };
  });

---

<BaseLayout jsonld={[buildOrganizationLD(), buildPersonLD(), buildSearchActionLD()]}>
  <Header activeNav="daily" />
  <Masthead
    todayCount={todayCount}
    totalCount={totalCount}
    lastPublishedAt={latest?.data.publishedAt}
    dataUpdatesToday={todaySignals.dataUpdatesToday}
    draftsInQueue={todaySignals.draftsInQueue}
  />

  <main id="main" role="main">
  <Hero
    entry={latest}
    chartLabel={ecosSpotlight ? '오늘의 지표' : undefined}
    chartTitle={ecosSpotlight?.title}
    chartValue={ecosSpotlight?.value}
    chartUnit={ecosSpotlight?.unit}
    chartDelta={ecosSpotlight?.delta}
    chartSource={ecosSpotlight?.source}
    chartHref={ecosSpotlight ? `/topic/${ecosSpotlight.topicId}/` : undefined}
  />

  <!-- Section 01b: 오늘의 핵심 지표 (한국은행 ECOS 매일 자동 갱신) -->
  <section class="section section-key-econ" data-screen-label="01b 핵심 지표">
    <div class="page-width">
      <div class="key-econ-head">
        <div class="key-econ-eyebrow">오 늘 의 · 핵 심 지 표</div>
        <a href="/data/timeseries/" class="key-econ-more">전체 시계열 →</a>
      </div>
      <div class="key-econ-grid">
        <EconomyChart ecosId="base-rate" compact />
        <EconomyChart ecosId="usd-krw" compact />
        <EconomyChart ecosId="cpi" compact />
      </div>
    </div>
  </section>

  <!-- Section 01c: 오늘의 데이터 (3 레인 — ECOS Δ + 정부 RSS 신착 + 뉴스 키워드) -->
  <TodayDataDigest />

  <!-- Section 02: 오늘의 펄스 -->
  <section class="section" data-screen-label="02 최신 펄스">
    <div class="page-width">
      <SectionHead num="02" title="오늘의 펄스" moreHref="#" moreLabel="데일리 전체 →" />
      <PulseList>
        {pulseCards.map((p) => <PulseCard {...p} />)}
      </PulseList>
    </div>
  </section>

  <!-- Section 03: 분야별 최신 -->
  <section class="section" data-screen-label="03 카테고리">
    <div class="page-width">
      <SectionHead num="03" title="분야별 최신" moreLabel="5개 카테고리 · 활자 라벨로만 구분" />
      <CategoryStrip>
        {categories.map((c) => <CategoryColumn {...c} />)}
      </CategoryStrip>
    </div>
  </section>

  <!-- Section 04: 진행 중인 가이드북 — 컬렉션 비어 있으면 섹션 자체 미렌더 (Eng #2) -->
  {guidebooks.length > 0 && (
    <section class="section" id="guidebook" data-screen-label="04 가이드북">
      <div class="page-width">
        <SectionHead num="04" title="진행 중인 가이드북" moreLabel={`${guidebooks.length}권`} />
        <div class="guidebook-grid">
          {guidebooks.map((g) => <GuidebookCard {...g} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Section 05: 오늘의 추천 차트 -->
  <section class="section" id="data" data-screen-label="05 추천 차트">
    <div class="page-width">
      <SectionHead num="05" title="오늘의 추천 차트" moreHref="/data/timeseries/" moreLabel="데이터 전체 →" />
      <EconomyChart ecosId="usd-krw" />
    </div>
  </section>

  <NewsletterCTA />
  </main>

  <Footer />
</BaseLayout>

<style>
  .guidebook-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 720px) {
    .guidebook-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* 핵심 지표 섹션 (Section 01b) */
  .section-key-econ { padding-top: 24px; padding-bottom: 24px; }
  .key-econ-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .key-econ-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--color-accent);
  }
  .key-econ-more {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-link);
    letter-spacing: 0.04em;
  }
  .key-econ-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 880px) {
    .key-econ-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .key-econ-grid { grid-template-columns: 1fr; }
  }
  /* EconomyChart 의 자체 .ec-card 마진과 충돌 회피 — 그리드 안에서는 0 */
  .key-econ-grid :global(.ec-card),
  .key-econ-grid :global(.ec-empty) { margin: 0; }
</style>
