---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** OG 이미지 절대 URL. 미지정 시 사이트 기본 og-default.png 사용. */
  ogImage?: string;
  /** OG 타입 — 일반 페이지는 'website', 기사는 'article' */
  ogType?: 'website' | 'article';
  /** 기사 발행일 (ogType='article'일 때만 사용) */
  ogPublishedAt?: string;
  /** 기사 수정일 (ogType='article'일 때만 사용) */
  ogModifiedAt?: string;
  /**
   * JSON-LD 구조화 데이터.
   * 단일 객체 또는 객체 배열 — 호출자가 필요할 때만 전달, 없으면 head에 아무 것도 주입하지 않는다.
   */
  jsonld?: object | object[];
}

const {
  title = '스마트데이터샵 — 한국의 데이터를 매일 5분으로',
  description = '한국의 정책·세금·금융·시장·통계·AI 1차 출처 데이터를 매일 5분 안에. 1차 출처 데이터 저널.',
  ogImage = 'https://smartdatashop.kr/og-default.png',
  ogType = 'website',
  ogPublishedAt,
  ogModifiedAt,
  jsonld,
} = Astro.props;

// 정규 URL — Astro.url은 빌드 시 site origin 기준 절대 URL을 만들어준다.
const canonicalUrl = Astro.url.toString();

// JSON-LD 배열 정규화 (단일 객체도 배열로 통일)
const jsonldArray: object[] = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="스마트데이터샵" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    {ogType === 'article' && ogPublishedAt && (
      <meta property="article:published_time" content={ogPublishedAt} />
    )}
    {ogType === 'article' && ogModifiedAt && (
      <meta property="article:modified_time" content={ogModifiedAt} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS / Sitemap discovery -->
    <link rel="alternate" type="application/rss+xml" title="스마트데이터샵 RSS" href="/feed.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
    />

    {jsonldArray.map((data) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
