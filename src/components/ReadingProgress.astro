---
/**
 * ReadingProgress — 기사 페이지 상단 hairline 진행률 표시.
 *
 * 사양:
 *   - position: fixed; top: 0; left: 0; height: 2px; z-index: 100
 *   - 너비는 scrollTop / (scrollHeight - innerHeight) * 100% (rAF 디바운스)
 *   - 짧은 페이지(스크롤 불필요)에선 아예 보이지 않음
 *   - prefers-reduced-motion 사용자에겐 transition 제거 (전역 ReducedMotion이 처리)
 *
 * 마운트:
 *   - ArticleLayout 상단에서만 1회 마운트한다 (인사이트는 호출자 판단으로 추가 가능).
 *   - 페이지 전체 길이를 진행률 기준으로 쓰므로 IntersectionObserver보다 scroll/rAF가 단순.
 */
---

<div class="reading-progress" role="presentation" aria-hidden="true">
  <div class="reading-progress-bar" data-reading-progress></div>
</div>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 100;
    pointer-events: none;
    background: transparent;
  }
  .reading-progress-bar {
    height: 100%;
    width: 0;
    background: var(--color-accent);
    transform-origin: left center;
    transition: width 60ms linear;
  }
</style>

<script>
  // 전역 1회 등록 — 같은 페이지에 두 번 마운트되더라도 querySelector('[data-reading-progress]')
  // 가 첫 번째 요소를 채택하므로 충돌 없음.
  (() => {
    const bar = document.querySelector<HTMLDivElement>('[data-reading-progress]');
    if (!bar) return;

    let ticking = false;

    const update = () => {
      const doc = document.documentElement;
      const scrollTop = window.scrollY || doc.scrollTop;
      const scrollHeight = doc.scrollHeight - window.innerHeight;
      if (scrollHeight <= 0) {
        bar.style.width = '0%';
        return;
      }
      const ratio = Math.min(1, Math.max(0, scrollTop / scrollHeight));
      bar.style.width = `${ratio * 100}%`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>
