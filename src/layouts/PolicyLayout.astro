---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** 페이지 상단 카테고리 라벨 — 예: "정 책 페 이 지" */
  eyebrow?: string;
  /** 마지막 갱신일 — 문자열 그대로 노출 */
  updatedAt?: string;
}

const { title, description, eyebrow = '정 책', updatedAt } = Astro.props;
---

<BaseLayout title={`${title} — 스마트데이터샵`} description={description ?? title}>
  <Header />

  <main class="policy-wrap">
    <header class="policy-header">
      <div class="policy-eyebrow">{eyebrow}</div>
      <h1 class="policy-title">{title}</h1>
      {updatedAt && <p class="policy-updated">마지막 갱신: {updatedAt}</p>}
    </header>

    <article class="policy-body">
      <slot />
    </article>
  </main>

  <Footer vol="I" no="89" date="2026년 5월 5일 화" />
</BaseLayout>

<style>
  .policy-wrap {
    max-width: var(--width-prose);
    margin: 0 auto;
    padding: 56px var(--width-gutter) 64px;
  }
  @media (max-width: 640px) {
    .policy-wrap { padding: 40px var(--width-gutter) 48px; }
  }

  .policy-header {
    border-bottom: 0.5px solid var(--color-ink-quat);
    padding-bottom: 18px;
    margin-bottom: 36px;
  }
  .policy-eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--color-ink-secondary);
    margin-bottom: 12px;
  }
  .policy-title {
    font-family: var(--font-serif);
    font-size: 32px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 500;
    margin: 0;
  }
  @media (max-width: 640px) {
    .policy-title { font-size: 26px; }
  }
  .policy-updated {
    margin: 12px 0 0;
    font-size: 12px;
    color: var(--color-ink-tertiary);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }

  .policy-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.4;
    letter-spacing: -0.005em;
    font-weight: 500;
    margin: 2.5rem 0 1rem;
  }
  .policy-body :global(h3) {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.5;
    margin: 1.75rem 0 0.5rem;
  }
  .policy-body :global(p) {
    margin: 0 0 1.25rem;
    line-height: 1.85;
  }
  .policy-body :global(ul),
  .policy-body :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }
  .policy-body :global(li) { margin-bottom: 0.35rem; }
  .policy-body :global(.todo) {
    display: block;
    border: 0.5px solid var(--color-accent-soft);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 12px 16px;
    margin: 1rem 0 1.5rem;
    font-size: 13px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }
  .policy-body :global(.meta-table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    font-size: 14px;
  }
  .policy-body :global(.meta-table th),
  .policy-body :global(.meta-table td) {
    text-align: left;
    padding: 10px 12px;
    border-bottom: 0.5px solid var(--color-ink-quat);
    vertical-align: top;
  }
  .policy-body :global(.meta-table th) {
    width: 30%;
    font-weight: 500;
    color: var(--color-ink-secondary);
    font-size: 13px;
    letter-spacing: 0.02em;
  }
</style>
