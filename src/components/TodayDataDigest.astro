---
/**
 * TodayDataDigest — 메인 "오늘의 데이터" 3 레인 섹션 (P1).
 *
 * 펄스 발행 = 0 인 날에도 메인이 매일 갱신되는 활동을 보이도록 cron 자동
 * fetch 결과 SSOT 데이터에서 직접 읽어 노출:
 *   1. ECOS 시계열 |Δ%| 상위 3 — 기준금리·환율·CPI·KOSPI·가계대출 중
 *   2. 정부 RSS 신착 5 — pubDateISO 최신 (605건 풀에서)
 *   3. 뉴스 화제 키워드 3 — 출처 ≥ 2개 등장 키워드 상위
 *
 * 가드레일:
 *   - DataHero LD 미포함 (P2 보류 — Dataset/NewsArticle 결정 신중)
 *   - RSS / 뉴스 항목은 외부 링크 (rel="external") — 본문 복제 X
 *   - 출처 없는 카드 노출 X (fail-soft 0 표시)
 *   - ECOS 만 내부 토픽 링크 (/topic/{id}/)
 */
import { getEcosTopChanges, getRecentRssItems, getTopNewsKeywords } from '../lib/today-signals';

interface Props {
  /** ECOS 변화 상위 N (기본 3). */
  ecosLimit?: number;
  /** 정부 RSS 신착 N (기본 5). */
  rssLimit?: number;
  /** 뉴스 키워드 N (기본 3). */
  newsLimit?: number;
}

const {
  ecosLimit = 3,
  rssLimit = 5,
  newsLimit = 3,
} = Astro.props;

const ecos = getEcosTopChanges(ecosLimit);
const rss = getRecentRssItems(rssLimit);
const news = getTopNewsKeywords(newsLimit);

const hasAny = ecos.length > 0 || rss.length > 0 || news.length > 0;

/** 절대값 보기 좋게 — 기본 소수 2자리, 정수면 0자리. */
function fmtNum(n: number): string {
  if (!Number.isFinite(n)) return '—';
  if (Math.abs(n) >= 100) return n.toLocaleString('ko-KR', { maximumFractionDigits: 0 });
  return n.toLocaleString('ko-KR', { maximumFractionDigits: 2 });
}

function fmtPct(n: number): string {
  if (!Number.isFinite(n)) return '—';
  const sign = n > 0 ? '+' : '';
  return `${sign}${n.toFixed(2)}%`;
}

function deltaClass(pct: number): string {
  if (!Number.isFinite(pct) || pct === 0) return 'flat';
  return pct > 0 ? 'up' : 'down';
}

/** "방금" / "N시간 전" / "N일 전" 한국어 짧은 라벨. */
function elapsedLabel(iso: string): string {
  const ms = Date.now() - new Date(iso).getTime();
  if (!Number.isFinite(ms) || ms < 0) return '';
  const hours = Math.floor(ms / (1000 * 60 * 60));
  if (hours < 1) return '방금';
  if (hours < 24) return `${hours}시간 전`;
  const days = Math.floor(hours / 24);
  if (days < 30) return `${days}일 전`;
  return new Date(iso).toLocaleDateString('ko-KR');
}
---

{hasAny && (
  <section class="section section-today-data" data-screen-label="01c 오늘의 데이터">
    <div class="page-width">
      <div class="tdd-head">
        <h2 class="tdd-title"><span class="num">01c</span>오늘의 데이터</h2>
        <span class="tdd-meta">한국은행·정부24·korea.kr·언론 7사 — 매일 자동 갱신</span>
      </div>

      <div class="tdd-grid">
        <!-- 레인 1: ECOS 변화 상위 -->
        <div class="tdd-lane">
          <div class="lane-eyebrow">핵심 지표 변화</div>
          {ecos.length === 0 ? (
            <p class="lane-empty">데이터 수집 대기 중</p>
          ) : (
            <ul class="lane-list">
              {ecos.map((row) => (
                <li class="ecos-row">
                  <a href={`/topic/${row.id}/`} class="no-underline ecos-link">
                    <div class="ecos-name">{row.short}</div>
                    <div class="ecos-value">
                      <span class="ec-num">{fmtNum(row.latestValue)}<span class="ec-unit">{row.unit}</span></span>
                      <span class={`ec-delta ec-${deltaClass(row.changePct)}`}>{fmtPct(row.changePct)}</span>
                    </div>
                    <div class="ecos-foot">{row.cycleLabel} 대비</div>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>

        <!-- 레인 2: 정부 RSS 신착 -->
        <div class="tdd-lane">
          <div class="lane-eyebrow">정부 신착</div>
          {rss.length === 0 ? (
            <p class="lane-empty">신착 항목 없음</p>
          ) : (
            <ul class="lane-list">
              {rss.map((row) => (
                <li class="rss-row">
                  <a href={row.link} rel="external noopener" class="no-underline rss-link">
                    <div class="rss-title">{row.title}</div>
                    <div class="rss-meta">
                      <span class="rss-source">{row.sourceName}</span>
                      <span class="dot">·</span>
                      <span class="rss-when">{elapsedLabel(row.publishedIso)}</span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>

        <!-- 레인 3: 뉴스 화제 키워드 -->
        <div class="tdd-lane">
          <div class="lane-eyebrow">언론 화제</div>
          {news.length === 0 ? (
            <p class="lane-empty">집계 대기 중</p>
          ) : (
            <ul class="lane-list">
              {news.map((row) => (
                <li class="news-row">
                  <div class="news-term-row">
                    <span class="news-term">{row.term}</span>
                    <span class="news-stat">{row.sourceCount}개사 · {row.total}건</span>
                  </div>
                  {row.exampleTitle && (
                    <div class="news-example" title={row.exampleTitle}>{row.exampleTitle}</div>
                  )}
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .section-today-data {
    padding: 40px 0;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .tdd-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .tdd-title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin: 0;
  }
  .tdd-title .num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    margin-right: 12px;
    vertical-align: 3px;
  }
  .tdd-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--color-ink-tertiary);
  }
  .tdd-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr 1fr;
    gap: 32px;
  }
  @media (max-width: 980px) {
    .tdd-grid { grid-template-columns: 1fr; gap: 24px; }
  }

  .tdd-lane {
    border-top: 0.5px solid var(--color-ink-quat);
    padding-top: 16px;
  }
  .lane-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-ink-tertiary);
    margin-bottom: 14px;
  }
  .lane-empty {
    font-size: 13px;
    color: var(--color-ink-tertiary);
    margin: 0;
    font-style: italic;
  }
  .lane-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* 레인 1: ECOS */
  .ecos-row .ecos-link {
    display: block;
    color: inherit;
    padding: 10px 0;
    border-bottom: 0.5px dashed var(--color-ink-quat);
    transition: background 0.15s ease;
  }
  .ecos-row .ecos-link:hover { background: var(--color-paper-soft); }
  .ecos-name {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--color-ink);
    margin-bottom: 4px;
  }
  .ecos-value {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 4px;
  }
  .ec-num {
    font-family: var(--font-mono);
    font-size: 19px;
    font-weight: 500;
    color: var(--color-ink);
  }
  .ec-unit {
    font-size: 11px;
    color: var(--color-ink-tertiary);
    margin-left: 3px;
    font-weight: 400;
  }
  .ec-delta {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
  }
  .ec-up { color: #a83a3a; }
  .ec-down { color: #2a7a3a; }
  .ec-flat { color: var(--color-ink-tertiary); }
  .ecos-foot {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.04em;
  }

  /* 레인 2: RSS */
  .rss-row .rss-link {
    display: block;
    color: inherit;
    padding-bottom: 12px;
    border-bottom: 0.5px dashed var(--color-ink-quat);
  }
  .rss-row .rss-link:hover .rss-title { color: var(--color-accent); }
  .rss-title {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-ink);
    margin-bottom: 4px;
    transition: color 0.15s ease;
  }
  .rss-meta {
    display: flex;
    gap: 4px;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.04em;
  }
  .rss-source { color: var(--color-ink-secondary); }
  .rss-meta .dot { color: var(--color-ink-quat); }

  /* 레인 3: News */
  .news-row {
    padding-bottom: 12px;
    border-bottom: 0.5px dashed var(--color-ink-quat);
  }
  .news-term-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 4px;
  }
  .news-term {
    font-family: var(--font-serif);
    font-size: 17px;
    color: var(--color-ink);
  }
  .news-stat {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--color-ink-tertiary);
    flex-shrink: 0;
  }
  .news-example {
    font-size: 11px;
    line-height: 1.5;
    color: var(--color-ink-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
</style>
