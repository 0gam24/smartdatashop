---
import { formatKoreanToday } from '../lib/korean';

interface Props {
  vol?: string;
  no?: string;
  date?: string;
}

// 기본값은 빌드 시점의 KST 오늘 — hourly scout bot 으로 매시간 자동 갱신.
const { vol = 'I', no = '89', date = formatKoreanToday() } = Astro.props;
---

<footer class="site-footer">
  <div class="page-width">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          스마트데이터샵<span class="footer-tld">.kr</span>
        </div>
        <div class="footer-meta-line">
          대표 김준혁 · 사업자등록번호 406-06-34485<br />
          인천광역시 계양구 새벌로 88, 302동 1007호<br />
          smartdatashop@gmail.com
        </div>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">콘 텐 츠</div>
        <ul>
          <li><a href="/">데일리 펄스</a></li>
          <li><a href="/insight/">인사이트</a></li>
          <li><span class="footer-link-pending" aria-disabled="true">가이드북 (준비 중)</span></li>
          <li><span class="footer-link-pending" aria-disabled="true">데이터 (준비 중)</span></li>
          <li><a href="/feed.xml">RSS</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">정 책</div>
        <ul>
          <li><a href="/about/">소개</a></li>
          <li><a href="/editorial-policy/">편집정책</a></li>
          <li><a href="/ai-policy/">AI 정책</a></li>
          <li><a href="/corrections/">정정 이력</a></li>
          <li><a href="/affiliate-disclosure/">제휴 공시</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">자 매 사 이 트</div>
        <ul>
          <li><a href="https://calculatorhost.com" rel="noopener noreferrer" target="_blank">calculatorhost.com</a></li>
          <li><a href="https://awoo.or.kr" rel="noopener noreferrer" target="_blank">awoo.or.kr</a></li>
          <li><a href="https://asiatop.co.kr" rel="noopener noreferrer" target="_blank">asiatop.co.kr</a></li>
          <li><a href="https://iknowhowinfo.com" rel="noopener noreferrer" target="_blank">iknowhowinfo.com</a></li>
          <li><a href="#network">네트워크 안내</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>
        © 2026 스마트데이터샵 — 본문 콘텐츠
        <a rel="license" href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="license noopener">CC BY-NC 4.0</a>
      </span>
      <span>VOL {vol} · NO {no} · {date}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 48px 0 32px;
    background: var(--color-paper);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 32px;
  }
  @media (max-width: 880px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
  .footer-brand {
    font-family: var(--font-serif);
    font-size: 18px;
    margin-bottom: 12px;
    color: var(--color-ink);
  }
  .footer-tld {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 12px;
    margin-left: 6px;
  }
  .footer-meta-line {
    font-size: 12px;
    color: var(--color-ink-secondary);
    line-height: 1.7;
  }
  .footer-col-title {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-ink-tertiary);
    margin-bottom: 12px;
    font-weight: 500;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col li {
    margin-bottom: 6px;
    font-size: 13px;
  }
  .footer-col a {
    color: var(--color-ink-secondary);
  }
  .footer-col a:hover {
    color: var(--color-ink);
  }
  /* 비활성 링크 — 콘텐츠 컬렉션이 비어 있어 라우트가 없는 경우 정직하게 표시 */
  .footer-col .footer-link-pending {
    color: var(--color-ink-tertiary);
    cursor: default;
  }

  .footer-bottom {
    padding-top: 24px;
    border-top: 0.5px solid var(--color-ink-quat);
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--color-ink-tertiary);
    flex-wrap: wrap;
    gap: 12px;
    letter-spacing: 0.02em;
  }
</style>
