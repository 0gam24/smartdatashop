---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Masthead from '../components/Masthead.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import PulseList from '../components/PulseList.astro';
import PulseCard from '../components/PulseCard.astro';
import CategoryStrip from '../components/CategoryStrip.astro';
import CategoryColumn from '../components/CategoryColumn.astro';
import GuidebookCard from '../components/GuidebookCard.astro';
import ChartFigure from '../components/ChartFigure.astro';
import SisterSiteGrid from '../components/SisterSiteGrid.astro';
import SisterSiteCard from '../components/SisterSiteCard.astro';
import ComingSoon from '../components/ComingSoon.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import Footer from '../components/Footer.astro';
import { categoryToKorean, formatKoreanTime, pulseUrl, pulseDateParts, type Category } from '../lib/korean';
import {
  buildOrganizationLD,
  buildPersonLD,
  buildSearchActionLD,
} from '../lib/jsonld';

// 섹션 02 — 오늘의 펄스 5편 (content collection 기반)
const allPulses = await getCollection('pulse');
const sortedPulses = allPulses.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
);
const latest = sortedPulses[0];
const pulseCards = sortedPulses.slice(0, 5).map((entry) => {
  const { personas, dataTypes, actions } = entry.data.tags;
  const tags = [
    ...personas.map((label) => ({ label, group: 'persona' as const })),
    ...dataTypes.map((label) => ({ label, group: 'data-type' as const })),
    ...actions.map((label) => ({ label, group: 'action' as const, action: true })),
  ].slice(0, 3);
  return {
    category: categoryToKorean(entry.data.category),
    time: formatKoreanTime(entry.data.publishedAt),
    title: entry.data.title,
    tldr: entry.data.tldr,
    href: pulseUrl(entry.slug, entry.data.publishedAt),
    tags,
  };
});

// 섹션 03 — 카테고리별 최신 (콘텐츠 컬렉션 기반)
//
// 편집 무결성 리팩토링 (Critical 3): 기존엔 5개 카테고리 × 3건 = 15건이
// 모두 가공된 헤드라인이었다 ("청년월세 특별지원 6월 마감, 잔여 예산 38%"
// 등). 사이트가 검수 전 디자인 샘플 단계라는 것을 독자에게 알리기 위해서는
// 홈에서도 실제 펄스 컬렉션의 글만 노출해야 한다. 카테고리에 글이 0건이면
// 빈 컬럼을 그대로 표시 — 그것 자체가 "아직 다루지 않은 분야"라는 정직한
// 신호다.
const CATEGORY_ORDER: Category[] = ['policy', 'tax-finance', 'market', 'stats', 'ai-tech'];
const groupedByCategory: Record<Category, typeof allPulses> = {
  policy: [],
  'tax-finance': [],
  market: [],
  stats: [],
  'ai-tech': [],
};
for (const e of allPulses) {
  groupedByCategory[e.data.category].push(e);
}

// 카테고리별 출처 라벨 — 펄스 첫 sources[0].name 에서 핵심 키워드 추출.
// 예: "통계청 4월 소비자물가동향" → "통계청"
function shortSourceName(fullName: string | undefined): string {
  if (!fullName) return '';
  const m = fullName.match(/^([^\s,(『「⌜]+)/);
  return m ? m[1] : fullName.slice(0, 8);
}

const categories = CATEGORY_ORDER.map((cat) => {
  const entriesInCat = groupedByCategory[cat]
    .slice()
    .sort(
      (a, b) =>
        new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
    );
  const items = entriesInCat.slice(0, 3).map((e, i) => {
    const { month, day } = pulseDateParts(e.data.publishedAt);
    const src = shortSourceName(e.data.sources[0]?.name);
    return {
      num: String(i + 1).padStart(2, '0'),
      title: e.data.title,
      meta: src ? `${month}.${day} · ${src}` : `${month}.${day}`,
      href: pulseUrl(e.slug, e.data.publishedAt),
    };
  });
  return {
    category: categoryToKorean(cat),
    count: `${entriesInCat.length}편`,
    items,
  };
});

// 섹션 04 — 진행 중인 가이드북
const guidebooks = [
  {
    coverNum: '1권 · 2026',
    coverTitle: '5월 종소세<br>완전 가이드',
    title: '5월 종합소득세 완전 가이드',
    description:
      '신고 대상 판단부터 모두채움·홈택스 단계별 캡처, 1인사업자 절세 전략까지. 1차 출처는 국세청 고시·해석례.',
    progressPct: 33,
    progressMeta: 'CHAPTER 4 / 12 · 완료율 33%',
    nextChapter: '인적공제 — 부양가족 판정 12가지',
    nextDate: '5월 8일',
  },
  {
    coverNum: '2권 · 2026 (예고)',
    coverTitle: '한국의<br>ETF 지도',
    title: '한국의 ETF 지도 — 시장·전략·세금',
    description:
      'KRX 상장 ETF 800종을 자산군·전략·과세체계 3축으로 분류. 자매 사이트 iknowhowinfo와 공동 기획.',
    progressPct: 8,
    progressMeta: 'CHAPTER 1 / 14 · 완료율 8%',
    nextChapter: 'ETF 분류의 3축',
    nextDate: '5월 12일',
  },
];

// 섹션 06 — 자매 사이트
const sisters = [
  {
    domain: 'calculatorhost.com',
    name: '계산기 호스트',
    persona: '즉답형 · 전 카테고리 횡단',
    latest: '종소세 환급액 계산기 — 모두채움 대비',
    baseUrl: 'https://calculatorhost.com',
  },
  {
    domain: 'awoo.or.kr',
    name: '아우',
    persona: '지원금 수령자',
    latest: '청년월세 특별지원 잔여 예산 38%',
    baseUrl: 'https://awoo.or.kr',
  },
  {
    domain: 'asiatop.co.kr',
    name: '머니룩',
    persona: '사회초년생 · 직장인',
    latest: '신혼부부 디딤돌 vs 보금자리론 비교',
    baseUrl: 'https://asiatop.co.kr',
  },
  {
    domain: 'iknowhowinfo.com',
    name: '아이노하우',
    persona: '투자자',
    latest: 'KOSPI200 ETF 4월 순유입 3.2조',
    baseUrl: 'https://iknowhowinfo.com',
  },
];
---

<BaseLayout jsonld={[buildOrganizationLD(), buildPersonLD(), buildSearchActionLD()]}>
  <Header activeNav="daily" />
  <Masthead vol="I" no="89" todayCount={5} totalCount={127} />

  <main id="main" role="main">
  <Hero entry={latest} />

  <!-- Section 02: 오늘의 펄스 -->
  <section class="section" data-screen-label="02 최신 펄스">
    <div class="page-width">
      <SectionHead num="02" title="오늘의 펄스" moreHref="#" moreLabel="데일리 전체 →" />
      <PulseList>
        {pulseCards.map((p) => <PulseCard {...p} />)}
      </PulseList>
    </div>
  </section>

  <!-- Section 03: 분야별 최신 -->
  <section class="section" data-screen-label="03 카테고리">
    <div class="page-width">
      <SectionHead num="03" title="분야별 최신" moreLabel="5개 카테고리 · 활자 라벨로만 구분" />
      <CategoryStrip>
        {categories.map((c) => <CategoryColumn {...c} />)}
      </CategoryStrip>
    </div>
  </section>

  <!-- Section 04: 진행 중인 가이드북 -->
  <section class="section" id="guidebook" data-screen-label="04 가이드북">
    <div class="page-width">
      <SectionHead num="04" title="진행 중인 가이드북" moreHref="#" moreLabel="전체 가이드북 →" />
      <div class="guidebook-grid">
        {guidebooks.map((g) => <GuidebookCard {...g} />)}
      </div>
    </div>
  </section>

  <!-- Section 05: 오늘의 추천 차트 -->
  <section class="section" id="data" data-screen-label="05 추천 차트">
    <div class="page-width">
      <SectionHead num="05" title="오늘의 추천 차트" moreHref="#" moreLabel="데이터 전체 →" />
      <ChartFigure />
    </div>
  </section>

  <!-- Section 06: 자매 사이트 네트워크 -->
  <section class="section" id="network" data-screen-label="06 자매 사이트">
    <div class="page-width">
      <SectionHead num="06" title="자매 사이트 네트워크" moreLabel="현재 4개 · 곧 합류 5개" />
      <SisterSiteGrid>
        {sisters.map((s) => <SisterSiteCard {...s} />)}
      </SisterSiteGrid>
      <ComingSoon />
    </div>
  </section>

  <NewsletterCTA />
  </main>

  <Footer vol="I" no="89" date="2026년 5월 5일 화" />
</BaseLayout>

<style>
  .guidebook-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 720px) {
    .guidebook-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
