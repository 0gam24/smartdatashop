</BaseLayout>

<script is:inline>
  (function () {
    var $ = function (id) { return document.getElementById(id); };
    var principal = $('c-principal');
    var rate = $('c-rate');
    var term = $('c-term');
    var grace = $('c-grace');
    var methodRadios = document.getElementsByName('c-method');

    function selectedMethod() {
      for (var i = 0; i < methodRadios.length; i++) {
        if (methodRadios[i].checked) return methodRadios[i].value;
      }
      return 'equal-payment';
    }
    function fmtWon(v) {
      if (!isFinite(v) || v < 0) return '–';
      return Math.round(v).toLocaleString('ko-KR') + '원';
    }
    function fmtEok(manwon) {
      var won = manwon * 10000;
      if (!isFinite(won) || won <= 0) return '';
      var eok = Math.floor(won / 100000000);
      var man = Math.round((won % 100000000) / 10000);
      var parts = [];
      if (eok > 0) parts.push(eok + '억');
      if (man > 0) parts.push(man.toLocaleString('ko-KR') + '만');
      return parts.length ? parts.join(' ') + ' 원' : (won.toLocaleString('ko-KR') + '원');
    }

    function calc() {
      var P = parseFloat(principal.value) * 10000;
      var annual = parseFloat(rate.value) / 100;
      var years = parseFloat(term.value);
      var g = parseInt(grace.value, 10) || 0;
      var method = selectedMethod();

      var hint = $('c-principal-hint');
      if (hint) hint.textContent = fmtEok(parseFloat(principal.value));

      var monthlyEl = $('c-monthly');
      var interestEl = $('c-interest');
      var totalEl = $('c-total');
      var monthsEl = $('c-months');
      var noteEl = $('c-note');
      var mainLabel = $('c-main-label');

      if (!(P > 0) || !(years > 0) || !(annual >= 0)) {
        monthlyEl.textContent = '–';
        interestEl.textContent = '–';
        totalEl.textContent = '–';
        monthsEl.textContent = '–';
        noteEl.textContent = '원금·이자율·기간을 올바르게 입력하세요.';
        return;
      }

      var N = Math.round(years * 12);
      var r = annual / 12;
      var amortMonths = N - g;
      if (amortMonths <= 0) {
        noteEl.textContent = '거치기간이 전체 대출기간보다 짧아야 합니다.';
        monthlyEl.textContent = '–';
        interestEl.textContent = '–';
        totalEl.textContent = '–';
        monthsEl.textContent = N + '개월';
        return;
      }

      var graceInterest = g * P * r;
      var totalInterest = 0;
      var noteParts = [];

      if (method === 'equal-payment') {
        var M;
        if (r === 0) M = P / amortMonths;
        else {
          var pow = Math.pow(1 + r, amortMonths);
          M = (P * r * pow) / (pow - 1);
        }
        totalInterest = graceInterest + (M * amortMonths - P);
        monthlyEl.textContent = fmtWon(M);
        mainLabel.textContent = '월 상환액 (매달 동일)';
        if (g > 0) noteParts.push('거치 중 월 이자 ' + fmtWon(P * r));
      } else {
        var principalPart = P / amortMonths;
        var amortInterest = 0;
        for (var i = 0; i < amortMonths; i++) {
          amortInterest += (P - principalPart * i) * r;
        }
        totalInterest = graceInterest + amortInterest;
        var firstPay = principalPart + P * r;
        var lastPay = principalPart + principalPart * r;
        monthlyEl.textContent = fmtWon(firstPay) + ' → ' + fmtWon(lastPay);
        mainLabel.textContent = '월 상환액 (첫달 → 마지막달)';
        if (g > 0) noteParts.push('거치 중 월 이자 ' + fmtWon(P * r));
      }

      interestEl.textContent = fmtWon(totalInterest);
      totalEl.textContent = fmtWon(P + totalInterest);
      monthsEl.textContent = g > 0 ? (N + '개월 (거치 ' + g + ')') : (N + '개월');
      noteEl.textContent = noteParts.join(' · ');
    }

    [principal, rate, term, grace].forEach(function (el) {
      if (el) el.addEventListener('input', calc);
    });
    for (var i = 0; i < methodRadios.length; i++) {
      methodRadios[i].addEventListener('change', calc);
    }
    calc();
  })();
</script>

