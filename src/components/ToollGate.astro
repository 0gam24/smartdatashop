---
/**
 * ToollGate (자매 사이트 라우팅 매트릭스 — PLANNING.md §12).
 *
 * 두 가지 모드:
 *  - 'route'         : 기존 동작 — primary 자매 사이트 라우팅 + 선택적 secondary 보조 라인.
 *  - 'main-terminal' : 별도 사이트 미런칭 카테고리 — 뉴스레터 구독 CTA 로 안내.
 *
 * 'route' 모드의 DOM/클래스 구조는 픽셀 매칭 시안 그대로 유지한다 (refactor 시 변경 금지).
 * 'main-terminal' 모드는 동일한 .tollgate 외곽을 재사용하되 내부만 교체한다.
 */

interface RouteProps {
  mode?: 'route';
  primaryText: string;
  primaryDomain: string;
  primaryHref: string;
  /** 보조 라인 텍스트 — 없으면 미렌더 */
  secondaryText?: string;
  /** 보조 라인 href — 있으면 보조 라인을 링크로 렌더, 없으면 plain text */
  secondaryHref?: string;
}

interface MainTerminalProps {
  mode: 'main-terminal';
  message: string;
}

type Props = RouteProps | MainTerminalProps;

const props = Astro.props as Props;
---

{props.mode === 'main-terminal' ? (
  <aside class="tollgate tollgate--terminal">
    <div class="label"><span class="arrow">↳</span> 더 깊이</div>
    <div class="terminal-message">{props.message}</div>
    <a href="/#newsletter" class="terminal-cta">뉴스레터 구독하기 →</a>
  </aside>
) : (
  <aside class="tollgate">
    <div class="label"><span class="arrow">↳</span> 더 깊이</div>
    <a href={props.primaryHref} class="primary">
      {props.primaryText}
      <span class="dot">·</span>
      <span class="domain">{props.primaryDomain} →</span>
    </a>
    {props.secondaryText && (
      props.secondaryHref ? (
        <a href={props.secondaryHref} class="secondary secondary--link">{props.secondaryText}</a>
      ) : (
        <div class="secondary">{props.secondaryText}</div>
      )
    )}
  </aside>
)}

<style>
  .tollgate {
    border-top: 0.5px solid var(--color-ink-quat);
    border-bottom: 0.5px solid var(--color-ink-quat);
    padding: 16px 0;
    margin: 32px 0;
  }
  .tollgate .label {
    font-size: 11px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    font-weight: 500;
  }
  .tollgate .arrow {
    color: var(--color-accent);
    margin-right: 4px;
  }
  .tollgate .primary {
    text-decoration: none;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink);
    display: block;
  }
  .tollgate .primary :global(.domain) {
    color: var(--color-accent);
    margin-left: 4px;
  }
  .tollgate .secondary {
    font-size: 12px;
    color: var(--color-ink-secondary);
    font-style: italic;
    margin-top: 4px;
    display: block;
  }
  .tollgate .secondary--link {
    text-decoration: none;
  }
  .tollgate .secondary--link:hover {
    color: var(--color-accent);
  }
  /* main-terminal 모드 — 동일한 .tollgate 외곽 + 내부만 교체 */
  .tollgate--terminal .terminal-message {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink);
  }
  .tollgate--terminal .terminal-cta {
    display: inline-block;
    margin-top: 6px;
    font-size: 13px;
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
