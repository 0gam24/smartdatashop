---
// 4열 자매 사이트 그리드 래퍼
---

<div class="sister-grid">
  <slot />
</div>

<style>
  .sister-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 0.5px solid var(--color-ink-quat);
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  @media (max-width: 980px) {
    .sister-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .sister-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
