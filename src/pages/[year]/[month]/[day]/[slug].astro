---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleLayout from '../../../../layouts/ArticleLayout.astro';
import Tldr from '../../../../components/Tldr.astro';
import RelatedList from '../../../../components/RelatedList.astro';
import ToollGate from '../../../../components/ToollGate.astro';
import { estimateReadingTime, pulseUrl, pulseDateParts, categoryToKorean } from '../../../../lib/korean';
import {
  buildNewsArticleLD,
  buildDatasetLDFromArticle,
  buildFaqLDFromMarkdown,
  buildHowToLDFromMarkdown,
} from '../../../../lib/jsonld';
import { entryHasPlaceholder } from '../../../../lib/placeholder';

export async function getStaticPaths() {
  const entries = await getCollection('pulse');
  return entries.map((entry) => {
    const { year, month, day } = pulseDateParts(entry.data.publishedAt);
    return {
      params: { year, month, day, slug: entry.slug },
      props: { entry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'pulse'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

// 본문 텍스트 길이로 읽기 시간 추정
const readingTime = estimateReadingTime(entry.body);

// 미완성 placeholder(`[검수 후 입력]` 등) 검출 시 robots noindex,nofollow 자동 부여.
// 검수 게이트 제거(2026-05) 이후 라이터 에이전트의 미완성 출력이 색인되는 사고를
// 빌드 시점에 자동으로 차단하기 위한 보조 안전망 — Layer 1.
const hasPlaceholder = entryHasPlaceholder({
  title: data.title,
  tldr: data.tldr,
  body: entry.body,
});

// SERP description은 Google 약 160자 제한 — tldr이 길면 잘라서 ellipsis 부착.
const description =
  data.tldr.length > 155 ? data.tldr.slice(0, 152).trim() + '…' : data.tldr;

// SEO — JSON-LD NewsArticle + Dataset (1차 출처 데이터 저널 차별화)
// Dataset 은 sources[].url 이 1개 이상 있을 때만 발행 (없으면 null 반환).
const articleJsonLd: object[] = [buildNewsArticleLD(entry)];
const datasetLd = buildDatasetLDFromArticle(entry, 'pulse');
if (datasetLd) articleJsonLd.push(datasetLd);

// GEO/SEO 고급화 — 본문에 FAQ 또는 본인 액션 단계 리스트가 있으면 자동 LD 발행
// FAQPage: LLM (ChatGPT/Perplexity/Gemini) 인용 시 Q&A 구조 보존
// HowTo: 본인 액션 체크리스트 → Google Discover + LLM 단계 추출 친화
const faqLd = buildFaqLDFromMarkdown(entry.body);
if (faqLd) articleJsonLd.push(faqLd);
const howToLd = buildHowToLDFromMarkdown(data.title, entry.body);
if (howToLd) articleJsonLd.push(howToLd);
// 명시적 coverImage 가 없으면 동적 OG v2(Satori, Reuters/Bloomberg 스타일)로 폴백.
// 구 librsvg 라우트(/og/pulse/<slug>.png)는 2026-06-12 제거 완료 (D9=N 1개월 병행 종료).
const ogImage = data.coverImage
  ? data.coverImage.startsWith('http')
    ? data.coverImage
    : `https://smartdatashop.kr${data.coverImage}`
  : `https://smartdatashop.kr/og/v2/pulse/${entry.slug}.png`;

// 페이지 keywords meta — Naver C-Rank/D.I.A. 신호로 페르소나·데이터유형·액션 태그 +
// 1차 출처 기관명 + 카테고리 라벨을 합쳐 노출 (07 §3 D.I.A. 핵심·보조 키워드 시그널 / 06 §5.3).
const sourceNames = (data.sources ?? [])
  .map((s) => s.name)
  .filter((n): n is string => typeof n === 'string' && n.length > 0)
  .slice(0, 5);
const keywords = Array.from(
  new Set([
    categoryToKorean(data.category),
    ...data.tags.personas,
    ...data.tags.dataTypes,
    ...data.tags.actions,
    ...sourceNames,
    '1차 출처',
    '데이터 저널',
  ]),
).filter(Boolean);

// 관련 글 — 같은 카테고리 다른 펄스 최근 3건
const allEntries = await getCollection('pulse');
const related = allEntries
  .filter((e) => e.slug !== entry.slug && e.data.category === entry.data.category)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3)
  .map((e) => {
    const { year, month, day } = pulseDateParts(e.data.publishedAt);
    return {
      when: `${year}.${month}.${day}`,
      title: e.data.title,
      href: pulseUrl(e.slug, e.data.publishedAt),
    };
  });
---

<ArticleLayout
  category={data.category}
  publishedAt={data.publishedAt}
  updatedAt={data.updatedAt}
  title={data.title}
  readingTime={readingTime}
  sources={data.sources}
  aiAssisted={data.aiAssisted}
  description={description}
  ogImage={ogImage}
  jsonld={articleJsonLd}
  keywords={keywords}
  corrections={data.correctionLog}
  noindex={hasPlaceholder}
>
  <Tldr>{data.tldr}</Tldr>
  <Content />

  {related.length > 0 && (
    <Fragment slot="related">
      <RelatedList items={related} />
    </Fragment>
  )}
</ArticleLayout>
