---
import PolicyLayout from '../layouts/PolicyLayout.astro';
import { getCollection } from 'astro:content';
import { pulseUrl, insightUrl, formatKoreanDate } from '../lib/korean';

// 모든 콘텐츠 컬렉션의 correctionLog 를 모아 시간순으로 정렬 (Ops #4, ADR 0005).
// 운영자가 글의 frontmatter `correctionLog: [{date, description}]` 에 한 줄 추가하면
// 본 페이지가 자동 갱신 — 별도 corrections.astro 본문 편집 불필요.
const allPulses = await getCollection('pulse');
const allInsights = await getCollection('insight');

interface CorrectionEntry {
  date: string;
  description: string;
  href: string;
  title: string;
  collection: 'pulse' | 'insight';
}

const corrections: CorrectionEntry[] = [];

for (const e of allPulses) {
  for (const c of e.data.correctionLog ?? []) {
    corrections.push({
      ...c,
      href: pulseUrl(e.slug, e.data.publishedAt),
      title: e.data.title,
      collection: 'pulse',
    });
  }
}
for (const e of allInsights) {
  for (const c of e.data.correctionLog ?? []) {
    corrections.push({
      ...c,
      href: insightUrl(e.slug),
      title: e.data.title,
      collection: 'insight',
    });
  }
}

corrections.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// 정정 신고 mailto 링크 (Risk #2 완화판) — 한국 독자 GitHub 계정 보유율 낮음.
// 운영자 이메일이 1차 채널, GitHub Issue 가 2차 백업.
const REPORT_EMAIL = 'editor@smartdatashop.kr';
const REPORT_GITHUB =
  'https://github.com/0gam24/smartdatashop/issues/new?labels=correction&title=%5B%EC%A0%95%EC%A0%95%EC%9A%94%EC%B2%AD%5D+';
---

<PolicyLayout
  title="정정 이력"
  eyebrow="정 책 · C O R R E C T I O N S"
  description="발행 후 발견된 사실·수치 오류 정정 이력 통합 페이지. 독자 정정 신고 채널 안내."
>
  <p>
    본 사이트는 발행 후 사실·수치 오류가 확인되면 본문 하단에 정정 이력을 기록하고,
    본 페이지에 통합합니다. 정정 절차는 <a href="/editorial-policy/">/editorial-policy/</a> 참조.
    AI 보조 작성 + 1차 출처 검증 워크플로우 는 <a href="/ai-policy/">/ai-policy/</a>.
  </p>

  <h2>정정 요청 채널</h2>
  <p>오류를 발견하시면 아래 채널 중 하나로 알려주세요. 운영자 직접 검토 후 24시간 내 답변, 정정 시 본 페이지에 공개 기록합니다.</p>
  <div class="report-channels">
    <a class="report-btn primary" href={`mailto:${REPORT_EMAIL}?subject=%5B%EC%A0%95%EC%A0%95%EC%9A%94%EC%B2%AD%5D%20`}>
      <span class="report-icon" aria-hidden="true">✉️</span>
      <span class="report-label">이메일로 보내기</span>
      <span class="report-meta">{REPORT_EMAIL}</span>
    </a>
    <a class="report-btn" href={REPORT_GITHUB} target="_blank" rel="noopener noreferrer">
      <span class="report-icon" aria-hidden="true">📝</span>
      <span class="report-label">GitHub Issue</span>
      <span class="report-meta">개발자 분이라면</span>
    </a>
  </div>

  <h2>정정 이력 — {corrections.length}건</h2>
  {corrections.length === 0 ? (
    <p class="empty-note">
      현재 정정 이력 0건. 본 사이트는 2026년 5월 발행 시작. 정정 사례 발생 시 본 페이지가 자동 갱신됩니다.
    </p>
  ) : (
    <ul class="correction-list">
      {corrections.map((c) => (
        <li class="correction-item">
          <div class="correction-date">{formatKoreanDate(c.date)}</div>
          <div class="correction-body">
            <a href={c.href} class="correction-title">{c.title}</a>
            <p class="correction-desc">{c.description}</p>
          </div>
        </li>
      ))}
    </ul>
  )}
</PolicyLayout>

<style is:global>
  /* PolicyLayout `.policy-body` 안 — :global 필요. */
  .policy-body .report-channels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 1rem 0 2rem;
  }
  @media (max-width: 560px) {
    .policy-body .report-channels {
      grid-template-columns: 1fr;
    }
  }
  .policy-body .report-btn {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 18px;
    border: 0.5px solid var(--color-ink-quat);
    background: var(--color-paper);
    color: var(--color-ink);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .policy-body .report-btn:hover {
    border-color: var(--color-accent-soft);
    background: var(--color-paper-soft);
  }
  .policy-body .report-btn.primary {
    background: var(--color-paper-soft);
    border-color: var(--color-accent-soft);
  }
  .policy-body .report-icon {
    font-size: 18px;
  }
  .policy-body .report-label {
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--color-ink);
  }
  .policy-body .report-meta {
    font-size: 12px;
    color: var(--color-ink-tertiary);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }
  .policy-body .empty-note {
    border-left: 2px solid var(--color-ink-quat);
    padding: 8px 0 8px 14px;
    color: var(--color-ink-secondary);
    font-style: normal;
  }
  .policy-body .correction-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }
  .policy-body .correction-item {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 18px;
    padding: 14px 0;
    border-top: 0.5px solid var(--color-ink-quat);
  }
  @media (max-width: 560px) {
    .policy-body .correction-item {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
  .policy-body .correction-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.04em;
  }
  .policy-body .correction-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--color-ink);
    margin-bottom: 4px;
    text-decoration: none;
  }
  .policy-body .correction-title:hover {
    color: var(--color-accent);
  }
  .policy-body .correction-desc {
    font-size: 14px;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0;
  }
</style>
