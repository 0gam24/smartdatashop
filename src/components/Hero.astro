---
/**
 * Hero — 홈 최상단 섹션 01.
 *
 * 편집 무결성:
 *   헤드라인·tldr·카테고리·발행시각·href 는 모두 콘텐츠 컬렉션의 최신
 *   pulse 엔트리에서 추출. 컴포넌트 내부에 어떤 수치도 하드코딩하지 않는다.
 *
 * 차트 어사이드("오늘의 지표"):
 *   chartTitle/chartValue/chartUnit/chartDelta/chartSource 5종이 모두
 *   명시적으로 전달될 때만 렌더된다. 기본값 0 정책 — 운영자가 1차 출처에서
 *   직접 가져온 수치만 노출되도록 하는 것이 의도이며, 미검증 수치가
 *   "오늘의 지표"로 보이는 사고를 차단한다.
 *
 * 사용:
 *   <Hero entry={latest} />                     ← 차트 미표시 (안전 기본)
 *   <Hero entry={latest}
 *         chartTitle="..." chartValue="..."
 *         chartUnit="..."  chartDelta="..."
 *         chartSource="..." />                  ← 운영자 명시 전달 시만 차트 표시
 */
import type { CollectionEntry } from 'astro:content';
import { categoryToKorean, formatKoreanDateTime, pulseUrl } from '../lib/korean';

interface Props {
  entry?: CollectionEntry<'pulse'>;
  chartLabel?: string;
  chartTitle?: string;
  chartValue?: string;
  chartUnit?: string;
  chartDelta?: string;
  chartSource?: string;
  /** 차트 카드 클릭 시 이동할 내부 링크 (e.g. /topic/base-rate/). 미지정 시 비클릭. */
  chartHref?: string;
}

const {
  entry,
  chartLabel = '오늘의 지표',
  chartTitle,
  chartValue,
  chartUnit,
  chartDelta,
  chartSource,
  chartHref,
} = Astro.props;

// 차트는 핵심 5종(title/value/unit/delta/source)이 모두 명시 전달될 때만 그린다.
// 어느 하나라도 비어 있으면 차트 어사이드 자체를 숨겨, 미검증 수치가 노출되는 사고 차단.
const hasChart =
  !!chartTitle && !!chartValue && !!chartUnit && !!chartDelta && !!chartSource;

// 펄스가 0건이면 hero 자체를 그리지 않는다 (graceful)
const hasEntry = entry !== undefined;
const category = hasEntry ? categoryToKorean(entry!.data.category) : '';
const publishedAt = hasEntry ? formatKoreanDateTime(entry!.data.publishedAt) : '';
const href = hasEntry ? pulseUrl(entry!.slug, entry!.data.publishedAt) : '#';
const title = hasEntry ? entry!.data.title : '';
const tldr = hasEntry ? entry!.data.tldr : '';
const aiAssisted = hasEntry ? entry!.data.aiAssisted : false;

// stale 감지 — 최신 펄스가 24h 이상 전이면 "최근 N일 전" 배지 노출.
// 운영자가 펄스 발행이 끊긴 동안 "왜 같은 글이 hero 에 박혀 있나" 인식 회피.
// (Plan 안 P0-2 — Discover/D.I.A. 신선도 신호 보조용 시각 단서)
function staleDayLabel(isoString: string): string | null {
  const elapsed = Date.now() - new Date(isoString).getTime();
  const days = Math.floor(elapsed / (1000 * 60 * 60 * 24));
  return days >= 1 ? `${days}일 전` : null;
}
const staleLabel = hasEntry ? staleDayLabel(entry!.data.publishedAt) : null;
---

{hasEntry && (
  <section class="hero" data-screen-label="01 Hero">
    <div class="page-width">
      <div class={hasChart ? 'hero-grid' : 'hero-grid hero-grid-single'}>
        <div>
          <div class="hero-meta">
            <span class="cat-label">{category}</span>
            <span class="meta">{publishedAt}</span>
            {staleLabel && <span class="stale-badge" title="최신 펄스 발행 후 경과">{staleLabel}</span>}
          </div>
          <h1 class="hero-headline">
            <a href={href} class="no-underline headline-link">{title}</a>
          </h1>
          <p class="hero-tldr">{tldr}</p>
          <div class="hero-byline">
            <span>김준혁</span><span class="dot">·</span>
            <span>5분 읽기</span>
            {aiAssisted && <span class="ai-badge">AI 보조</span>}
          </div>
        </div>

        {hasChart && (
          chartHref ? (
            <a href={chartHref} class="hero-chart hero-chart-link no-underline" aria-label={`${chartTitle} 토픽 상세`}>
              <div class="hero-chart-label">{chartLabel}</div>
              <div class="hero-chart-title">{chartTitle}</div>
              <div class="hero-chart-value">
                <span class="num">{chartValue}<span class="num-unit">{chartUnit}</span></span>
                <span class="delta">{chartDelta}</span>
              </div>
              <div class="hero-chart-source">{chartSource}</div>
            </a>
          ) : (
            <aside class="hero-chart">
              <div class="hero-chart-label">{chartLabel}</div>
              <div class="hero-chart-title">{chartTitle}</div>
              <div class="hero-chart-value">
                <span class="num">{chartValue}<span class="num-unit">{chartUnit}</span></span>
                <span class="delta">{chartDelta}</span>
              </div>
              <div class="hero-chart-source">{chartSource}</div>
            </aside>
          )
        )}
      </div>
    </div>
  </section>
)}

<style>
  .hero {
    padding: 56px 0 48px;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 56px;
    align-items: start;
  }
  /* 차트 어사이드 미표시 시 단일 컬럼 — 헤드라인이 prose 폭을 차지 */
  .hero-grid.hero-grid-single {
    grid-template-columns: 1fr;
  }
  @media (max-width: 880px) {
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .hero { padding: 32px 0; }
  }

  .hero-meta {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 18px;
  }
  .stale-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    border: 0.5px solid var(--color-ink-quat);
    padding: 2px 6px;
    background: var(--color-paper-soft);
  }
  .hero-headline {
    font-family: var(--font-serif);
    font-size: 44px;
    line-height: 1.25;
    letter-spacing: -0.02em;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0 0 18px;
    cursor: pointer;
  }
  .hero-headline .headline-link {
    color: inherit;
  }
  @media (max-width: 880px) {
    .hero-headline { font-size: 30px; }
  }
  .hero-tldr {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-ink-secondary);
    margin-bottom: 28px;
    max-width: 580px;
  }
  .hero-byline {
    font-size: 13px;
    color: var(--color-ink-secondary);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
  }

  .hero-chart {
    border: 0.5px solid var(--color-ink-quat);
    padding: 20px 22px;
    background: var(--color-paper);
  }
  /* 토픽 페이지 링크 버전 — 색상 상속 + 호버 시 살짝 강조 */
  a.hero-chart-link {
    display: block;
    color: inherit;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  a.hero-chart-link:hover {
    background: var(--color-paper-soft);
    border-color: var(--color-accent-soft);
  }
  a.hero-chart-link:hover .hero-chart-title {
    color: var(--color-accent);
  }
  .hero-chart-title {
    transition: color 0.15s ease;
  }
  .hero-chart-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-ink-tertiary);
    margin-bottom: 6px;
    font-weight: 500;
  }
  .hero-chart-title {
    font-family: var(--font-serif);
    font-size: 16px;
    margin-bottom: 14px;
    color: var(--color-ink);
  }
  .hero-chart-value {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 12px;
  }
  .hero-chart-value .num {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .hero-chart-value .num-unit {
    font-size: 18px;
    color: var(--color-ink-secondary);
    font-family: var(--font-sans);
  }
  .hero-chart-value .delta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-secondary);
  }
  .hero-chart-source {
    margin-top: 10px;
    font-size: 11px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.02em;
  }
</style>
