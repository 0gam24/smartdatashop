---
/**
 * Chart.js CDN 로더 — 페이지당 1회만 주입.
 *
 * package.json에 chart.js를 추가하지 않고 CDN으로만 로드한다.
 * defer 속성으로 비동기 로드, 컴포넌트 측 스크립트는 window.Chart가
 * 준비될 때까지 폴링하여 안전하게 차트를 초기화.
 *
 * 사용처: ChartFigure.astro 등 Chart.js를 필요로 하는 컴포넌트.
 */
---

<script
  is:inline
  defer
  src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"
  data-chartjs-loader></script>
