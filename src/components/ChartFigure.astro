---
// 섹션 5: 추천 차트 — 좌 통계/우 라인차트 (Chart.js 인터랙티브)
//
// Chart.js 4.4.0을 CDN으로 로드 (package.json 의존성 추가 없음).
// ChartLib 컴포넌트가 페이지당 1회 <script defer>로 주입.
import ChartLib from './ChartLib.astro';
---

<ChartLib />

<div class="featured-chart">
  <div>
    <div class="fc-meta-label">통 계 · 일 갱 신</div>
    <h3 class="fc-title">원/달러 환율, 6주 만에 1,360원대 회복</h3>
    <p class="fc-desc">
      한국은행 ECOS 일일 종가 기준. 4월 28일 1,387원 고점 이후 5거래일 연속 하락. 5월 FOMC 의사록 발표를 앞두고 외환시장 변동성은 12.4%로 평년 수준.<sup class="fn">[3]</sup>
    </p>
    <div class="fc-stats">
      <div class="fc-stat">
        <div class="fc-stat-label">5월 5일 종가</div>
        <div class="fc-stat-value">1,362.40<span class="unit">원</span></div>
        <div class="fc-stat-delta down">▼ −24.6 (−1.78%)</div>
      </div>
      <div class="fc-stat">
        <div class="fc-stat-label">52주 변동폭</div>
        <div class="fc-stat-value">1,287 — 1,397</div>
        <div class="fc-stat-delta">+8.5% YoY</div>
      </div>
      <div class="fc-stat">
        <div class="fc-stat-label">변동성 (30D)</div>
        <div class="fc-stat-value">12.4<span class="unit">%</span></div>
        <div class="fc-stat-delta down">평년 13.1%</div>
      </div>
      <div class="fc-stat">
        <div class="fc-stat-label">갱신 시각</div>
        <div class="fc-stat-value fc-stat-value-mono">2026-05-05 18:00</div>
        <div class="fc-stat-delta">출처: BOK ECOS</div>
      </div>
    </div>
  </div>

  <div class="fc-chart-frame">
    <div class="fc-chart-head">
      <div class="fc-chart-title-sm">원/달러 환율 (KRW/USD) — 일 종가</div>
      <div class="fc-chart-toggle" id="fc-chart-toggle">
        <button type="button" data-range="1M">1M</button>
        <button type="button" data-range="3M" class="on">3M</button>
        <button type="button" data-range="1Y">1Y</button>
        <button type="button" data-range="5Y">5Y</button>
      </div>
    </div>
    <div class="fc-canvas-wrap">
      <canvas id="fc-krwusd-chart" aria-label="원/달러 환율 추이 차트" role="img"></canvas>
    </div>
    <div class="fc-chart-foot">
      <span id="fc-chart-from">2026-02-05</span>
      <span>출처: 한국은행 ECOS · 일 종가 기준</span>
      <span id="fc-chart-to">2026-05-05</span>
    </div>
  </div>
</div>

<script is:inline>
  // =====================================================================
  // 샘플 데이터 — BOK ECOS 연동 시 실데이터로 교체
  // =====================================================================
  // PLANNING.md §16: 1차 출처는 한국은행 ECOS Open API (M1+). 현재는 차트
  // 인터랙션 검증용 더미 시계열. 실제 환율 추세를 모사하되 예측/실제값으로
  // 오인되지 않도록 마스트헤드 출처 라벨에서 "샘플"임을 명시할 것.
  // =====================================================================
  (function () {
    const SAMPLE_DATA = {
      // 1개월 (~22 영업일)
      '1M': {
        from: '2026-04-05',
        to: '2026-05-05',
        labels: ['04-05','04-08','04-11','04-14','04-17','04-22','04-25','04-28','05-01','05-05'],
        values: [1378.2, 1382.5, 1385.1, 1383.9, 1380.4, 1386.0, 1387.4, 1387.0, 1378.1, 1362.4],
      },
      // 3개월
      '3M': {
        from: '2026-02-05',
        to: '2026-05-05',
        labels: ['02-05','02-19','03-04','03-18','04-01','04-15','04-28','05-05'],
        values: [1325.4, 1331.0, 1342.7, 1356.3, 1368.9, 1382.5, 1387.0, 1362.4],
      },
      // 1년
      '1Y': {
        from: '2025-05-05',
        to: '2026-05-05',
        labels: ['25-05','25-07','25-09','25-11','26-01','26-03','26-05'],
        values: [1287.3, 1295.0, 1308.6, 1322.4, 1318.0, 1352.1, 1362.4],
      },
      // 5년
      '5Y': {
        from: '2021-05-05',
        to: '2026-05-05',
        labels: ['2021','2022','2023','2024','2025','2026'],
        values: [1118.5, 1271.3, 1305.8, 1330.2, 1295.0, 1362.4],
      },
    };

    const PALETTE = {
      paper: '#faf7f0',
      ink: '#1a1a1a',
      inkSoft: '#6b6b6b',
      inkTertiary: '#707070', /* WCAG AA 5.0:1 vs paper — global.css 토큰과 동기화 */
      inkQuat: '#cccccc',     /* hairline 용 (텍스트 미사용) */
      accent: '#8b1538',
    };

    const reduceMotion =
      typeof window.matchMedia === 'function'
        ? window.matchMedia('(prefers-reduced-motion: reduce)').matches
        : false;

    let chartInstance = null;
    let currentRange = '3M';

    function buildConfig(range) {
      const data = SAMPLE_DATA[range];
      const lastIdx = data.values.length - 1;

      return {
        type: 'line',
        data: {
          labels: data.labels,
          datasets: [
            {
              data: data.values,
              borderColor: PALETTE.ink,
              borderWidth: 1.4,
              pointRadius: data.values.map((_, i) => (i === lastIdx ? 3 : 0)),
              pointBackgroundColor: data.values.map((_, i) =>
                i === lastIdx ? PALETTE.accent : PALETTE.ink,
              ),
              pointBorderColor: data.values.map((_, i) =>
                i === lastIdx ? PALETTE.accent : PALETTE.ink,
              ),
              pointHoverRadius: 4,
              pointHoverBackgroundColor: PALETTE.accent,
              pointHoverBorderColor: PALETTE.accent,
              fill: false,
              tension: 0.25,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: reduceMotion ? false : { duration: 400 },
          interaction: { intersect: false, mode: 'index' },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: PALETTE.paper,
              borderColor: PALETTE.inkQuat,
              borderWidth: 0.5,
              titleColor: PALETTE.ink,
              titleFont: { family: 'JetBrains Mono, monospace', size: 10, weight: '500' },
              bodyColor: PALETTE.ink,
              bodyFont: { family: 'JetBrains Mono, monospace', size: 11 },
              padding: 8,
              displayColors: false,
              cornerRadius: 0,
              callbacks: {
                title: (items) => (items[0] ? items[0].label : ''),
                label: (ctx) => `${Number(ctx.parsed.y).toFixed(2)} 원`,
              },
            },
          },
          scales: {
            x: {
              display: false,
              grid: { display: false },
            },
            y: {
              position: 'right',
              border: { display: false },
              grid: {
                color: PALETTE.inkQuat,
                lineWidth: 0.5,
                drawTicks: false,
                tickLength: 0,
                // dashed hairlines (Chart.js 4: borderDash on grid)
              },
              ticks: {
                color: PALETTE.inkTertiary,
                font: { family: 'JetBrains Mono, monospace', size: 9 },
                padding: 6,
                maxTicksLimit: 4,
              },
            },
          },
        },
      };
    }

    function applyDashedGrid(chart) {
      // Chart.js 4: scale.options.grid.borderDash
      if (chart && chart.options && chart.options.scales && chart.options.scales.y) {
        chart.options.scales.y.grid.borderDash = [2, 4];
      }
    }

    function render(range) {
      currentRange = range;
      const canvas = document.getElementById('fc-krwusd-chart');
      if (!canvas || !window.Chart) return;
      const data = SAMPLE_DATA[range];
      const fromEl = document.getElementById('fc-chart-from');
      const toEl = document.getElementById('fc-chart-to');
      if (fromEl) fromEl.textContent = data.from;
      if (toEl) toEl.textContent = data.to;

      if (chartInstance) {
        chartInstance.destroy();
      }
      chartInstance = new window.Chart(canvas.getContext('2d'), buildConfig(range));
      applyDashedGrid(chartInstance);
      chartInstance.update();
    }

    function bindToggle() {
      const toggle = document.getElementById('fc-chart-toggle');
      if (!toggle) return;
      toggle.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof HTMLElement)) return;
        const btn = target.closest('button[data-range]');
        if (!btn) return;
        const range = btn.getAttribute('data-range');
        if (!range || !SAMPLE_DATA[range]) return;
        toggle.querySelectorAll('button').forEach((b) => b.classList.remove('on'));
        btn.classList.add('on');
        render(range);
      });
    }

    function waitForChartJs(maxAttempts = 50) {
      let attempts = 0;
      const interval = setInterval(() => {
        attempts += 1;
        if (window.Chart) {
          clearInterval(interval);
          render(currentRange);
          bindToggle();
        } else if (attempts >= maxAttempts) {
          clearInterval(interval);
          // CDN 실패 fallback: 캔버스 자리에 안내 텍스트 (디버그용 콘솔 메시지)
          // 정적 SVG로 되돌리지는 않음 — 빈 차트 영역 유지.
          // eslint-disable-next-line no-console
          console.warn('[ChartFigure] Chart.js CDN 로드 실패');
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitForChartJs);
    } else {
      waitForChartJs();
    }
  })();
</script>

<style>
  .featured-chart {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 880px) {
    .featured-chart {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .fc-meta-label {
    color: var(--color-ink-tertiary);
    font-size: 11px;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    font-weight: 500;
  }
  .fc-title {
    font-family: var(--font-serif);
    font-size: 26px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 14px;
    font-weight: 500;
  }
  .fc-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-ink-secondary);
    margin-bottom: 20px;
  }

  .fc-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 0.5px solid var(--color-ink-quat);
  }
  .fc-stat {
    padding: 12px 0;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .fc-stat:nth-child(odd) { padding-right: 16px; }
  .fc-stat:nth-child(even) {
    padding-left: 16px;
    border-left: 0.5px solid var(--color-ink-quat);
  }
  .fc-stat-label {
    font-size: 11px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .fc-stat-value {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .fc-stat-value.fc-stat-value-mono {
    font-size: 14px;
    font-family: var(--font-mono);
  }
  .fc-stat-value .unit {
    font-size: 13px;
    color: var(--color-ink-secondary);
    margin-left: 2px;
    font-family: var(--font-sans);
  }
  .fc-stat-delta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    margin-top: 2px;
    letter-spacing: 0.02em;
  }
  .fc-stat-delta.down {
    color: #1f4d8a;
  }

  .fc-chart-frame {
    border: 0.5px solid var(--color-ink-quat);
    padding: 24px 28px 20px;
    background: var(--color-paper);
  }
  .fc-chart-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 0.5px solid var(--color-ink-quat);
  }
  .fc-chart-title-sm {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--color-ink);
  }
  .fc-chart-toggle {
    display: flex;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-ink-tertiary);
  }
  .fc-chart-toggle button {
    background: none;
    border: 0;
    font: inherit;
    color: inherit;
    cursor: pointer;
    padding: 0;
    transition: color 0.12s ease;
  }
  .fc-chart-toggle button:hover {
    color: var(--color-ink-secondary);
  }
  .fc-chart-toggle button.on {
    color: var(--color-accent);
  }
  .fc-canvas-wrap {
    position: relative;
    width: 100%;
    min-height: 240px;
    height: 240px;
  }
  .fc-canvas-wrap canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }
  .fc-chart-foot {
    display: flex;
    justify-content: space-between;
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.04em;
  }
</style>
