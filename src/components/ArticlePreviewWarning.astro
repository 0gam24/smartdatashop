---
/**
 * ArticlePreviewWarning — per-article 프리뷰 경고 박스.
 *
 * 표시 조건: previewMode === true 일 때만 렌더. 그 외에는 null.
 *
 * 디자인 의도(편집 헌장 §"AI 보조를 숨기지 않는다 — 단, 데이터 검증과
 * 최종 판단은 운영자가 한다"):
 *   - 사이트 전역의 PreviewBanner는 사용자가 닫을 수 있고, 그 사실 자체로
 *     특정 글의 수치가 아직 1차 출처와 대조되지 않았다는 경고로는
 *     약하다. 따라서 본문(슬롯) 최상단, Tldr 위에 글마다 영구적으로
 *     박혀 있는 별도 경고 박스가 필요하다 — Critical 3 (편집 무결성)
 *     가 요구하는 "수치는 미검증" 라벨.
 *   - 와인 액센트 좌측 룰 + paper-soft 배경으로 신문지 톤은 유지하되,
 *     컬러 위계로 "본문보다 강한 메모" 효과를 낸다.
 *
 * 위치: ArticleLayout / InsightLayout 의 .article-body 슬롯 직전.
 * (Tldr 위, 본문 시작 시 가장 먼저 눈에 들어오는 자리)
 */
interface Props {
  previewMode?: boolean;
}

const { previewMode = false } = Astro.props;
---

{previewMode && (
  <aside class="article-preview-warning" role="note" aria-label="디자인 프리뷰 경고">
    <div class="apw-rule" aria-hidden="true"></div>
    <div class="apw-body">
      <p class="apw-lede">
        <span class="apw-icon" aria-hidden="true">🚧</span>
        <strong class="apw-title">디자인 프리뷰 — 본 글은 운영자(편집·검증 책임자) 검수 전 디자인 샘플입니다.</strong>
      </p>
      <p class="apw-detail">
        본문에 등장하는 수치·인용·기관 발표 일자 등은 1차 출처와 대조되기 전이므로
        사실로 인용하지 마십시오. 정식 발행 시 verifiedBy 표기와 함께 정확한 1차 출처
        링크가 추가됩니다.
      </p>
    </div>
  </aside>
)}

<style>
  .article-preview-warning {
    display: flex;
    gap: 14px;
    align-items: stretch;
    background: var(--color-paper-soft, #f4f0e6);
    padding: 16px 18px 14px;
    margin: 0 0 28px;
    /* 본문 시작 신호 — Tldr 위쪽 여백을 잡아주되 첫 인상은 박스 자체가 가져간다 */
  }
  .apw-rule {
    flex: 0 0 auto;
    width: 2px;
    background: var(--color-accent, #8b1538);
    align-self: stretch;
  }
  .apw-body {
    flex: 1 1 auto;
    min-width: 0;
  }
  .apw-lede {
    margin: 0 0 6px;
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-ink, #1a1a1a);
    display: flex;
    gap: 8px;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .apw-icon {
    flex: 0 0 auto;
    font-size: 13px;
  }
  .apw-title {
    font-weight: 600;
    color: var(--color-ink, #1a1a1a);
    letter-spacing: -0.005em;
  }
  .apw-detail {
    margin: 0;
    font-size: 12px;
    line-height: 1.65;
    color: var(--color-ink-secondary, #6b6b6b);
  }
  @media (max-width: 640px) {
    .article-preview-warning {
      padding: 14px 14px 12px;
      gap: 12px;
      margin-bottom: 22px;
    }
    .apw-lede {
      font-size: 12.5px;
    }
    .apw-detail {
      font-size: 11.5px;
    }
  }
</style>
