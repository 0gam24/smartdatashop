---
/**
 * 가이드북 인덱스 — /guidebook/
 *
 * 책 2권 시점부터 헤더 nav 가 단일 책으로 점프하기 어색해 인덱스 페이지 신설.
 * Ralph 회차 10 — 콘텐츠 글쓰기 0줄, 컴포넌트·LD 재사용만.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import GuidebookCard from '../../components/GuidebookCard.astro';
import {
  buildBreadcrumbLD,
  buildCollectionPageLD,
  buildItemListLD,
} from '../../lib/jsonld';

const books = await getCollection('guidebook').catch(() => []);
const sorted = books.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
);

const cards = sorted.map((entry) => {
  const totalCh = entry.data.totalChapters;
  const doneCh = entry.data.completedChapters;
  const pct = totalCh > 0 ? Math.round((doneCh / totalCh) * 100) : 0;
  const slug = entry.id.replace(/\.json$/, '');
  return {
    coverNum: entry.data.title.split(/\s+/)[0] ?? '·',
    coverTitle: entry.data.title,
    title: entry.data.title,
    description: entry.data.description,
    progressPct: pct,
    progressMeta: `CHAPTER ${doneCh} / ${totalCh} · 완료율 ${pct}%`,
    nextChapter: '',
    nextDate: '',
    href: `/guidebook/${slug}/`,
  };
});

const pageUrl = '/guidebook/';
const pageTitle = '가이드북 — 스마트데이터샵';
const pageDescription = '한국의 정책·세금·금융 1차 출처 가이드북. 챕터별 무료 공개, 1차 출처 검증, CC BY-NC 4.0.';

const collectionLd = buildCollectionPageLD(pageTitle, pageDescription, pageUrl);
const breadcrumbLd = buildBreadcrumbLD([
  { name: '홈', url: '/' },
  { name: '가이드북', url: pageUrl },
]);
const listLd = buildItemListLD(
  cards.map((c) => ({ name: c.title, url: c.href })),
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  jsonld={[collectionLd, breadcrumbLd, listLd]}
>
  <Header activeNav="guidebook" />

  <main id="main" role="main" class="gb-index">
    <header class="gb-index-header">
      <div class="gb-eyebrow">가 이 드 북</div>
      <h1 class="gb-title">한국 데이터로 만든 가이드북</h1>
      <p class="gb-desc">
        정책·세금·금융 1차 출처를 챕터 단위로 정리한 무료 공개 가이드북.
        모든 글은 CC BY-NC 4.0 으로 인용·재배포 가능.
      </p>
    </header>

    {cards.length === 0 ? (
      <p class="gb-empty">아직 발행된 가이드북이 없습니다.</p>
    ) : (
      <div class="gb-grid">
        {cards.map((c) => <GuidebookCard {...c} />)}
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>

<style>
  .gb-index {
    max-width: var(--width-page);
    margin: 0 auto;
    padding: 56px var(--width-gutter) 64px;
  }
  .gb-index-header {
    border-bottom: 0.5px solid var(--color-ink-quat);
    padding-bottom: 28px;
    margin-bottom: 36px;
    max-width: var(--width-prose);
  }
  .gb-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: 14px;
  }
  .gb-title {
    font-family: var(--font-serif);
    font-size: 32px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 500;
    margin: 0 0 14px;
  }
  @media (max-width: 640px) {
    .gb-title {
      font-size: 26px;
    }
  }
  .gb-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink-secondary);
    margin: 0;
  }
  .gb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 720px) {
    .gb-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  .gb-empty {
    color: var(--color-ink-secondary);
  }
</style>
