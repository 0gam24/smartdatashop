---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  placeholder?: string;
  submitLabel?: string;
  footnote?: string;
}

const {
  eyebrow = '매일 오전 7시',
  title = '5분 데이터 브리핑',
  description = '정부24·국세청·KRX·BOK ECOS·KOSIS 1차 출처에서 추린 그날의 5편을 한 통의 메일로. 광고 없음, 수익 없음, 운영자 1인 발송.',
  placeholder = 'your@email.com',
  submitLabel = '구독하기',
  footnote = '언제든 한 번의 클릭으로 해지 · 개인정보 KISA 표준 양식 준수',
} = Astro.props;
---

<section class="newsletter" data-screen-label="07 뉴스레터">
  <div class="page-width newsletter-inner">
    <div class="newsletter-eyebrow">{eyebrow}</div>
    <h2 class="newsletter-title">{title}</h2>
    <p class="newsletter-desc">{description}</p>
    <form class="newsletter-form" id="newsletter-form">
      <input type="email" placeholder={placeholder} required />
      <button type="submit">{submitLabel}</button>
    </form>
    <div class="newsletter-foot">{footnote}</div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('newsletter-form');
    if (!form) return;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      if (btn) btn.textContent = '구독 완료';
    });
  });
</script>

<style>
  .newsletter {
    padding: 64px 0;
    border-bottom: 0.5px solid var(--color-ink-quat);
    background: var(--color-paper-soft);
  }
  .newsletter-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .newsletter-eyebrow {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 16px;
    font-weight: 500;
  }
  .newsletter-title {
    font-family: var(--font-serif);
    font-size: 32px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 14px;
    font-weight: 500;
  }
  @media (max-width: 640px) {
    .newsletter-title { font-size: 24px; }
  }
  .newsletter-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink-secondary);
    margin-bottom: 28px;
  }
  .newsletter-form {
    display: flex;
    gap: 0;
    max-width: 440px;
    margin: 0 auto;
    border: 0.5px solid var(--color-ink-quat);
    background: var(--color-paper);
  }
  .newsletter-form input {
    flex: 1;
    border: 0;
    background: transparent;
    padding: 14px 16px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-ink);
    outline: none;
  }
  .newsletter-form input::placeholder {
    color: var(--color-ink-tertiary);
  }
  .newsletter-form button {
    border: 0;
    border-left: 0.5px solid var(--color-ink-quat);
    background: transparent;
    padding: 0 22px;
    font-family: var(--font-sans);
    font-size: 13px;
    letter-spacing: 0.1em;
    color: var(--color-ink);
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .newsletter-form button:hover {
    background: var(--color-paper-deep);
  }
  .newsletter-foot {
    margin-top: 14px;
    font-size: 11px;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.05em;
  }
</style>
