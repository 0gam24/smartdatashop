---
import '../styles/global.css';
// 폰트 self-host (G23 픽스) + subset 분리 (Lighthouse CSS bundle size 픽스).
// Phase 16: noto-serif-kr 의 통합 `500.css` (92KB, subset 27 종) 대신 사용 subset
// (korean + latin) 만 import — 약 92x CSS 사이즈 절감. render-blocking CSS 가
// 209KB → ~10KB 수준으로 떨어져 LCP/FCP 개선 기대.
import '@fontsource/noto-serif-kr/korean-500.css';
import '@fontsource/noto-serif-kr/korean-600.css';
import '@fontsource/noto-serif-kr/latin-500.css';
import '@fontsource/noto-serif-kr/latin-600.css';
import '@fontsource/jetbrains-mono/latin-400.css';
import '@fontsource/jetbrains-mono/latin-500.css';
import SearchModal from '../components/SearchModal.astro';
import Prefetch from '../components/Prefetch.astro';
import SkipToContent from '../components/SkipToContent.astro';
import MobileBottomTabs from '../components/MobileBottomTabs.astro';
import ReducedMotion from '../components/ReducedMotion.astro';
import { buildOrganizationLD, buildSearchActionLD } from '../lib/jsonld';

interface Props {
  title?: string;
  description?: string;
  /** OG 이미지 절대 URL. 미지정 시 사이트 기본 og-default.png 사용. */
  ogImage?: string;
  /** OG 타입 — 일반 페이지는 'website', 기사는 'article' */
  ogType?: 'website' | 'article';
  /** 기사 발행일 (ogType='article'일 때만 사용) */
  ogPublishedAt?: string;
  /** 기사 수정일 (ogType='article'일 때만 사용) */
  ogModifiedAt?: string;
  /**
   * JSON-LD 구조화 데이터.
   * 단일 객체 또는 객체 배열 — 호출자가 필요할 때만 전달, 없으면 head에 아무 것도 주입하지 않는다.
   */
  jsonld?: object | object[];
  /**
   * 페이지별 키워드 메타. 미지정 시 meta keywords를 렌더하지 않는다.
   * Naver C-Rank/D.I.A. 신호용으로 카테고리·태그·인사이트 페이지에서만 채운다.
   */
  keywords?: string[];
  /**
   * BaseLayout이 기본 robots 메타(index,follow,max-image-preview:large)를
   * 출력하지 않도록 막는다. /article 같이 자체 noindex가 필요한 페이지에서 사용.
   */
  noBaseRobots?: boolean;
  /**
   * true 일 때 robots 메타를 `noindex,nofollow,max-image-preview:large` 로
   * 출력한다. `noBaseRobots` 보다 우선순위가 높다 — 동적 라우트에서
   * placeholder 미완성 글을 자동으로 색인 차단할 때 사용.
   * Layer 1 안전망 (검수 게이트 제거에 따른 보조 차단).
   */
  noindex?: boolean;
}

const {
  title = '스마트데이터샵 — 한국의 데이터를 매일 5분으로',
  description = '한국의 정책·세금·금융·시장·통계·AI 1차 출처 데이터를 매일 5분 안에. 1차 출처 데이터 저널.',
  // 기본 OG 는 동적 home 카드 (Satori v2). 글마다 고유 이미지 정책 (G17 픽스) —
  // og-default.png 는 PWA manifest 등 정적 자산 폴백 용도로만 잔존.
  ogImage = 'https://smartdatashop.kr/og/v2/home.png',
  ogType = 'website',
  ogPublishedAt,
  ogModifiedAt,
  jsonld,
  keywords,
  noBaseRobots = false,
  noindex = false,
} = Astro.props;

// 정규 URL — Astro.url은 빌드 시 site origin 기준 절대 URL을 만들어준다.
const canonicalUrl = Astro.url.toString();

/**
 * 검색엔진 사이트 소유권 확인 메타.
 *
 * - PUBLIC_NAVER_SITE_VERIFICATION: 네이버 서치어드바이저(https://searchadvisor.naver.com)
 *   에서 도메인 등록 후 발급되는 토큰. 미지정 시 메타가 출력되지 않는다.
 * - PUBLIC_GOOGLE_SITE_VERIFICATION: 구글 서치 콘솔(https://search.google.com/search-console)
 *   에서 도메인 등록 후 발급되는 토큰. 미지정 시 메타가 출력되지 않는다.
 *
 * 토큰은 Cloudflare Pages 환경변수에 그대로 넣어 PR/preview 빌드는 비워둔 채
 * 운영 빌드에서만 메타가 노출되도록 한다.
 */
const naverSiteVerification = import.meta.env.PUBLIC_NAVER_SITE_VERIFICATION as
  | string
  | undefined;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION as
  | string
  | undefined;

// og:image MIME 추정 — SVG 확장자는 image/svg+xml, 그 외(.png/.jpg/.webp 등)는 image/png 기본.
// 사이트의 모든 OG 이미지는 1200x630 표준이므로 width/height는 고정값으로 둔다.
const ogImageMime = ogImage.toLowerCase().endsWith('.svg')
  ? 'image/svg+xml'
  : 'image/png';

// JSON-LD 배열 정규화 (단일 객체도 배열로 통일)
const jsonldArray: object[] = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];

// 모든 페이지 자동 주입 — Organization + WebSite LD (Naver 사이트링크 검색창 + Google E-E-A-T)
// 06 §13.4 사이트 이름 / 07 §8.5 리치결과
const autoLD: object[] = [];
function hasType(arr: object[], t: string): boolean {
  return arr.some((o: any) => o?.['@type'] === t);
}
// Organization (NewsMediaOrganization) — 호출자 미지정 시 자동
if (!hasType(jsonldArray, 'NewsMediaOrganization') && !hasType(jsonldArray, 'Organization')) {
  autoLD.push(buildOrganizationLD());
}
// WebSite (SearchAction 내장) — 호출자 미지정 시 자동
if (!hasType(jsonldArray, 'WebSite')) {
  autoLD.push(buildSearchActionLD());
}
const finalJsonldArray = [...autoLD, ...jsonldArray];

/**
 * Cloudflare Web Analytics — privacy-friendly, cookieless beacon.
 *
 * Enable by setting `PUBLIC_CF_ANALYTICS_TOKEN` in the Cloudflare Pages
 * environment (Settings → Environment variables) to the site token shown
 * in the Cloudflare dashboard under Web Analytics → your site → Manage Site.
 * If the variable is unset, no script is rendered (prevents broken beacons
 * on local builds and PR previews without the secret).
 *
 * The beacon is also suppressed during `astro dev` so analytics never
 * counts developer page views.
 */
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN as string | undefined;
const enableCfAnalytics = import.meta.env.PROD && !!cfAnalyticsToken;

/**
 * Google AdSense client ID — 사이트 소유권 인증 + 광고 게재용.
 *
 * publisher ID 형식: `ca-pub-XXXXXXXXXXXXXXXX` (16자리 숫자).
 * 사이트 루트의 `/ads.txt` 와 본 스크립트가 동시 존재 시 AdSense 인증 안정성 ↑.
 *
 * 운영자 publisher ID 는 공개 정보 — fallback 하드코딩 사용.
 * 운영자 변경 시 env (`PUBLIC_ADSENSE_CLIENT`) 로 override 가능.
 */
const ADSENSE_CLIENT_FALLBACK = 'ca-pub-7830821732287404';
const adsenseClient =
  (import.meta.env.PUBLIC_ADSENSE_CLIENT as string | undefined) || ADSENSE_CLIENT_FALLBACK;
const enableAdsense = import.meta.env.PROD && /^ca-pub-\d+$/.test(adsenseClient);

/**
 * Google Analytics 4 (GA4) — 트래픽 분석.
 *
 * Measurement ID 형식: `G-XXXXXXXXXX` (10자리 영숫자).
 * 운영자 발급 절차:
 *   1. Google Analytics 4 → 관리 → 속성 → 데이터 스트림
 *   2. 웹 스트림 만들기 → smartdatashop.kr 입력
 *   3. 측정 ID 복사 → 본 사이트 env (`PUBLIC_GA4_MEASUREMENT_ID`) 등록
 *
 * env 미설정 시 미주입 — GA4 데이터 수집 X.
 */
const GA4_MEASUREMENT_FALLBACK = 'G-1BEF2TDWMF';
const ga4MeasurementId =
  (import.meta.env.PUBLIC_GA4_MEASUREMENT_ID as string | undefined) || GA4_MEASUREMENT_FALLBACK;
const enableGa4 = import.meta.env.PROD && /^G-[A-Z0-9]{8,12}$/.test(ga4MeasurementId);

/**
 * 네이버 애널리틱스 — 한국 검색 트래픽 정밀 분석 (C-Rank / D.I.A. 연동).
 *
 * 발급 ID 형식: 12-20자 hex (예: `a12608dc4b99a8`).
 * 운영자 발급 ID 는 공개 정보 — fallback 하드코딩 사용.
 * 운영자 변경 시 env (`PUBLIC_NAVER_ANALYTICS_ID`) 로 override 가능.
 */
const NAVER_ANALYTICS_FALLBACK = 'a12608dc4b99a8';
const naverAnalyticsId =
  (import.meta.env.PUBLIC_NAVER_ANALYTICS_ID as string | undefined) || NAVER_ANALYTICS_FALLBACK;
const enableNaverAnalytics =
  import.meta.env.PROD && /^[a-f0-9]{12,20}$/.test(naverAnalyticsId);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && keywords.length > 0 && (
      <meta name="keywords" content={keywords.join(',')} />
    )}
    <meta name="author" content="김준혁" />
    {noindex ? (
      <meta name="robots" content="noindex,nofollow,max-image-preview:large" />
    ) : (
      !noBaseRobots && (
        <meta name="robots" content="index,follow,max-image-preview:large" />
      )
    )}
    {naverSiteVerification && (
      <meta name="naver-site-verification" content={naverSiteVerification} />
    )}
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="스마트데이터샵" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={ogImageMime} />
    {ogType === 'article' && ogPublishedAt && (
      <meta property="article:published_time" content={ogPublishedAt} />
    )}
    {ogType === 'article' && ogModifiedAt && (
      <meta property="article:modified_time" content={ogModifiedAt} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Feed / Sitemap discovery -->
    <link rel="alternate" type="application/rss+xml" title="스마트데이터샵 RSS" href="/feed.xml" />
    <link rel="alternate" type="application/feed+json" title="스마트데이터샵 JSON Feed" href="/feed.json" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* 서드파티 preconnect — lighthouse uses-rel-preconnect (광고·GA 오리진 핸드셰이크 선행) */}
    {enableAdsense && <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />}
    {enableGa4 && <link rel="preconnect" href="https://www.googletagmanager.com" />}

    {/* Google AdSense — 사이트 소유권 인증 + 자동 광고 게재 (PUBLIC_ADSENSE_CLIENT 설정 시만 PROD) */}
    {enableAdsense && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
      ></script>
    )}

    {/* Google Analytics 4 — PROD + PUBLIC_GA4_MEASUREMENT_ID 설정 시만 */}
    {enableGa4 && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
        <script is:inline set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${ga4MeasurementId}', { anonymize_ip: true });
        `}></script>
      </>
    )}


    <!-- 라이선스 머신-가독 (Risk #4): CC BY-NC 4.0 — Dataset LD 의 license 와 일치. -->
    <link rel="license" href="https://creativecommons.org/licenses/by-nc/4.0/" />

    <!-- Same-page Korean alternate (helps crawlers confirm primary language) -->
    <link rel="alternate" hreflang="ko" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- PWA + theming -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#faf7f0" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="스마트데이터샵" />

    <!-- Favicons -->
    <!-- Favicons — SVG 우선 (모든 모던 브라우저), 32 PNG fallback (구형/Google SERP),
         192 PNG (PWA), apple-touch-icon (iOS 홈 스크린). 모두 단일 SVG 에서 자동 생성:
         scripts/generate-favicons.mjs (--rebuild). -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Performance: Pretendard CDN 만 외부 (한국 모바일 캐시 적중률 높음).
         Noto Serif KR + JetBrains Mono 는 self-host (G23). Pretendard 는 비동기 로딩
         (`media="print" onload` 트릭) 으로 LCP 차단 회피 — Lighthouse render-blocking 픽스.
         JS 미작동 환경(<noscript>)에서도 정상 표시되도록 fallback 유지. -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
      />
    </noscript>

    {finalJsonldArray.map((data) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
    ))}

    {enableCfAnalytics && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}
  </head>
  <!--
    id="main-body" 는 SkipToContent의 secondary fallback 식별자.
    1차 점프 타깃은 소비 레이아웃의 <main id="main">. (Article/Policy/Insight)
    main 요소가 없는 페이지(index 등)에서는 해당 페이지에서 <main id="main"> 래퍼를 추가한다.
  -->
  <body id="main-body">
    <ReducedMotion />
    <SkipToContent />
    <SearchModal />
    <slot />
    <MobileBottomTabs />
    <Prefetch />

    {/*
      네이버 애널리틱스 — 네이버 공식 권장 위치: </body> 직전.
      PROD + 발급 ID 형식 검증 시만 (fallback 'a12608dc4b99a8' / env override 가능).
      페이지 로드 영향 최소화 + 본문 렌더 후 추적.
    */}
    {enableNaverAnalytics && (
      <>
        <script async src="https://wcs.pstatic.net/wcslog.js"></script>
        <script is:inline set:html={`
          if (!wcs_add) var wcs_add = {};
          wcs_add["wa"] = "${naverAnalyticsId}";
          if (window.wcs) {
            wcs_do();
          }
        `}></script>
      </>
    )}
  </body>
</html>
